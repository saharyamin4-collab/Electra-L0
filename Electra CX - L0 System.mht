let _expandedId=null;
function toggleClExpand(id){
  const body=document.getElementById('clxb-'+id);
  const chev=document.getElementById('chev-'+id);
  const card=document.getElementById('clc-'+id);
  if(!body)return;
  const isOpen=body.classList.contains('open');
  // close any other open one
  if(_expandedId&&_expandedId!==id){
    const ob=document.getElementById('clxb-'+_expandedId);
    const oc=document.getElementById('chev-'+_expandedId);
    const oc2=document.getElementById('clc-'+_expandedId);
    if(ob)ob.classList.remove('open');
    if(oc)oc.style.transform='rotate(0deg)';
    if(oc2)oc2.classList.remove('clc-active');
  }
  if(isOpen){
    body.classList.remove('open');
    chev.style.transform='rotate(0deg)';
    card.classList.remove('clc-active');
    _expandedId=null;
  } else {
    body.classList.add('open');
    chev.style.transform='rotate(180deg)';
    card.classList.add('clc-active');
    _expandedId=id;
    setTimeout(()=>card.scrollIntoView({behavior:'smooth',block:'nearest'}),60);
  }
}

function deleteCl(id){
  if(!isAuthed){requireAuth(()=>deleteCl(id));return;}
  const code=prompt('ОћОќОЪ ОДОЋОЊ ОљОЎОЕОЋОе ОюОъОЌОЎОДОћ (electra1234):');
  if(code!==ADMIN_PASS){toast('РЮї ОДОЋОЊ ОЕОњОЋОЎ Рђћ ОъОЌОЎОДОћ ОЉОЋОўОюОћ');return;}
  if(!confirm('ОюОъОЌОЋОД "'+(allCls[id]?.title||id)+'" ОюОдОъОЎОфОЋОф?'))return;
  db.ref('checklists/'+id).remove().then(()=>{delete allCls[id];renderHome();toast('­ЪЌЉ№ИЈ ОаОъОЌОД');}).catch(()=>toast('ОЕОњОЎОљОћ ОЉОъОЌОЎОДОћ'));
}
function duplicateCl(id,e){
  e.stopPropagation();if(!isAuthed){toast('­Ъћњ ОаОЊОеОЕОф ОћОеОЕОљОћ');return;}
  const src=allCls[id];if(!src)return;toast('­ЪЊІ ОЎОЋОдОе ОбОЋОфОД...');
  const newId='cl_'+Date.now();
  const meta={...src,title:src.title+' (ОбОЋОфОД)',status:'not-started',created:new Date().toLocaleDateString('he-IL'),updated:new Date().toLocaleDateString('he-IL'),passed:0,failed:0,na:0,openIssues:0,closedIssues:0,waitingIssues:0};
  allCls[newId]=meta;db.ref('checklists/'+newId+'/meta').set(meta).catch(()=>{});
  db.ref('checklists/'+id+'/data').once('value').then(snap=>{
    const data=snap.val();if(!data)return;
    const nd={v:12,ts:Date.now(),status:'not-started',panel:meta.title,proj:data.proj||'',insp:data.insp||'',mfr:data.mfr||'',fdate:'',notes:'',sigs:data.sigs||[],items:{},actLog:[]};
    Object.keys(data.items||{}).forEach(k=>{nd.items[k]={s:'X',note:data.items[k]?.note||'',issues:[]};});
    db.ref('checklists/'+newId+'/data').set(nd).then(()=>toast('РюЁ ОбОЋОфОД ОаОЋОдОе')).catch(()=>{});
  }).catch(()=>{});
}
function exportAllCSV(){
  const all=Object.keys(allCls);if(!all.length){toast('ОљОЎОЪ Од\'ОДОюОЎОАОўОЎОЮ');return;}
  let csv='\uFEFFОЊОЋОЌ ОЏОю ОћОд\'ОДОюОЎОАОўОЎОЮ Рђћ Electra CX\n\n';
  csv+='ОюОЋОЌ,ОцОеОЋОЎОДОў,ОЉОЋОЊОД,ОфОљОеОЎОџ,ОАОўОўОЋОА,Passed,Failed,N/A,Issues ОцОфОЋОЌОЎОЮ,ОъОъОфОЎОЪ,ОАОњОЋОеОЎОЮ,%\n';
  all.forEach(id=>{const cl=allCls[id];const p=cl.passed||0,f=cl.failed||0,na=cl.na||0,tot=cl.total||31,pct=Math.round((p+f)/tot*100);csv+='"'+(cl.title||'')+'","'+(cl.proj||'')+'","'+(cl.insp||'')+'","'+(cl.fdate||cl.created||'')+'","'+(cl.status||'')+'",'+p+','+f+','+na+','+(cl.openIssues||0)+','+(cl.waitingIssues||0)+','+(cl.closedIssues||0)+','+pct+'%\n';});
  const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv;charset=utf-8;'}));a.download='Electra_All_'+new Date().toLocaleDateString('he-IL').replace(/\//g,'-')+'.csv';a.click();toast('РюЁ CSV ОЎОЋОдОљ');
}

