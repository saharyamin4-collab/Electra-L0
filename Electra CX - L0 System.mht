    (isAuthed?'<textarea class="ita" id="iact-'+itemId+'-'+idx+'" placeholder="ОцОбОЋОюОћ ОаОЊОеОЕОф..." oninput="schedSave();">'+(data.action||'')+'</textarea>':'')+
