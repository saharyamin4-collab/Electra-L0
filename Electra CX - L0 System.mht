      : '<button class="create-iss-btn" id="cib-'+itemId+'-'+idx+'" onclick="confirmIss('+itemId+','+idx+')"'+(data.confirmed?' style="display:none;"':'')+'>РюЁ ОдОЋОе Issue</button>'
    );
  // restore issue photos
  if(data.photos?.length){
    if(!issuePhotos[itemId])issuePhotos[itemId]={};
    if(!issuePhotos[itemId][idx])issuePhotos[itemId][idx]=[];
    const row=document.getElementById('ibp-'+itemId+'-'+idx);
    data.photos.forEach(p=>{
      if(!p)return;
      const url=typeof p==='string'?p:(p.url||null);
