// OPEN Рђћ uses .once() to prevent duplicate issues bug
// РЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљ
function enterCl(id){
  // Hide home, show checklist Рђћ no new tab, no scroll junk
  document.getElementById('sc-home').classList.remove('on');
  CID=id; resetCl(); switchTab('cl');
  // Scroll to very top immediately
  const content=document.querySelector('.content');
  if(content)content.scrollTop=0;
  window.scrollTo(0,0);
  _loadClData(id);
}
function openCl(id){
  if(!isAuthed){requireAuth(()=>enterCl(id));return;}
  enterCl(id);
}
function viewCl(id){ enterCl(id); }
function leaveChecklist(){
  if(CID)forceSave();
  CID=null;
  // Hide checklist screens, show home
  ['sc-cl','sc-issues','sc-dash'].forEach(id=>{
    document.getElementById(id)?.classList.remove('on');
  });
  document.getElementById('sc-home').classList.add('on');
  document.getElementById('tabs').classList.remove('show');
  // Scroll to top of home
  const content=document.querySelector('.content');
  if(content)content.scrollTop=0;
  window.scrollTo(0,0);
  goHome(); loadHome();
}
function _loadClData(id){
  let localData=null;
  try{const s=localStorage.getItem('cl_'+id);if(s)localData=JSON.parse(s);}catch(e){}
  // Apply local immediately Рђћ never wait for network
  if(localData)apply(localData);
  // Check Firebase Рђћ override ONLY if strictly more than 2s newer (= different device)
  db.ref('checklists/'+id+'/data').once('value').then(snap=>{
    const fb=snap.val();
    if(!fb)return;
    if(!localData){
      apply(fb);
      try{localStorage.setItem('cl_'+id,JSON.stringify(fb));}catch(e){}
      return;
    }
    if((fb.ts||0)>(localData.ts||0)+2000){
      apply(fb);
      try{localStorage.setItem('cl_'+id,JSON.stringify(fb));}catch(e){}
    }
    // local is fresher Рђћ push it to Firebase to keep in sync
    else if((localData.ts||0)>(fb.ts||0)){
      db.ref('checklists/'+id+'/data').set(localData).catch(()=>{});
    }
  }).catch(()=>{});
}

// РЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљ
