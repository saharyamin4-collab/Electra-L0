    '<button onclick="confirmRestore('+idx+')" style="flex:2;background:linear-gradient(135deg,#2979ff,#1565c0);color:#fff;border:none;border-radius:10px;padding:13px;font-size:.82rem;font-weight:800;cursor:pointer;font-family:inherit;">­Ъћё ОЕОЌОќОе ОаОЉОЌОеОЎОЮ</button>'+
