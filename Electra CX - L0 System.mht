            <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
              <span style="font-size:.72rem;font-weight:800;color:#94a3b8;font-family:'JetBrains Mono',monospace;">#${idx}</span>
              <span style="font-size:.65rem;font-weight:700;padding:2px 8px;border-radius:20px;background:${stBg};color:${stColor};">${stLabel}</span>
              <span style="font-size:.62rem;font-weight:700;padding:2px 7px;border-radius:20px;background:rgba(0,0,0,.04);color:${prioColor};">${prioLabel}</span>
              ${confirmed?'':'<span style="font-size:.58rem;font-weight:700;padding:2px 6px;border-radius:20px;background:rgba(100,116,139,.1);color:#64748b;">ОўОЎОЋОўОћ</span>'}
            </div>
            <div style="font-size:.82rem;color:#1e293b;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${desc||'(ОюОюОљ ОцОЎОеОЋОў)'}</div>
