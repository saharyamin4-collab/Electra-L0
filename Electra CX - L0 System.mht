// РЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљ
// BACKUP SYSTEM Рђћ hourly auto + manual restore
// РЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљ
const BK_KEY='cx_backups';
const BK_MAX=10; // keep last 10 backups
let bkInterval=null;

function getBackups(){
  try{const s=localStorage.getItem(BK_KEY);return s?JSON.parse(s):[];}catch(e){return [];}
}
function saveBackups(arr){
  try{localStorage.setItem(BK_KEY,JSON.stringify(arr));}catch(e){
    // If localStorage full, drop oldest and retry
    try{arr=arr.slice(0,BK_MAX-2);localStorage.setItem(BK_KEY,JSON.stringify(arr));}catch(e2){}
  }
}

async function runBackup(manual=false){
  if(!navigator.onLine&&!manual){return;} // skip auto if offline
  const snapshot={};
  // Fetch all checklist data from Firebase
  try{
    const snap=await db.ref('checklists').once('value');
    const v=snap.val()||{};
    Object.keys(v).forEach(id=>{
      snapshot[id]={meta:v[id].meta||null,data:v[id].data||null};
    });
  }catch(e){
    // Fallback: use what we have in memory from allCls
    Object.keys(allCls).forEach(id=>{
      snapshot[id]={meta:allCls[id],data:null};
    });
    if(!Object.keys(snapshot).length){if(manual)toast('Рџа№ИЈ ОљОЎОЪ ОаОфОЋОаОЎОЮ ОюОњОЎОЉОЋОЎ');return;}
  }
  if(!Object.keys(snapshot).length){if(manual)toast('Рџа№ИЈ ОљОЎОЪ Од\'ОДОюОЎОАОўОЎОЮ ОюОњОЎОЉОЋОЎ');return;}

  const entry={
    ts:Date.now(),
    auto:!manual,
    data:snapshot,
    ver:3
  };
  const bks=getBackups();
  bks.unshift(entry);
  // Keep only BK_MAX entries
  if(bks.length>BK_MAX)bks.splice(BK_MAX);
  saveBackups(bks);
  // Also save to Firebase under backups/ node
  try{
    const bkKey='bk_'+Date.now();
    await db.ref('backups/'+bkKey).set({
      ts:entry.ts,auto:entry.auto,
      summary:{count:Object.keys(snapshot).length},
      data:snapshot
    });
    // Prune old Firebase backups Рђћ keep last 10
    const fbBks=await db.ref('backups').orderByKey().once('value');
    const keys=Object.keys(fbBks.val()||{}).sort();
    if(keys.length>BK_MAX){
      const toDelete=keys.slice(0,keys.length-BK_MAX);
      await Promise.all(toDelete.map(k=>db.ref('backups/'+k).remove()));
    }
  }catch(e){}

  if(manual)toast('РюЁ ОњОЎОЉОЋОЎ ОаОЕОъОе Рђћ '+Object.keys(snapshot).length+" Од'ОДОюОЎОАОўОЎОЮ");
  else console.log('[Electra CX] Auto backup done Рђћ',Object.keys(snapshot).length,'checklists');
}

function startAutoBackup(){
  if(bkInterval)return;
  bkInterval=setInterval(()=>runBackup(false),3600000); // every hour
  // Run once now if last backup > 1h ago
  const bks=getBackups();
  const last=bks[0]?.ts||0;
  if(Date.now()-last>3600000)setTimeout(()=>runBackup(false),5000);
}

function stopAutoBackup(){
  if(bkInterval){clearInterval(bkInterval);bkInterval=null;}
}

function toggleAutoBackup(btn){
  if(bkInterval){
    stopAutoBackup();
    btn.className='stog off';
    settings.autoBackup=false;saveSettings();
    toast('РЈИ ОњОЎОЉОЋОЎ ОљОЋОўОЋОъОўОЎ ОЏОЋОЉОћ');
  }else{
    startAutoBackup();
    btn.className='stog on';
    settings.autoBackup=true;saveSettings();
    toast('РюЁ ОњОЎОЉОЋОЎ ОљОЋОўОЋОъОўОЎ ОћОЋОцОбОю');
  }
}

function deleteBackup(idx){
  if(!confirm('ОюОъОЌОЋОД ОњОЎОЉОЋОЎ ОќОћ?'))return;
  const bks=getBackups();
  bks.splice(idx,1);
  saveBackups(bks);
  toast('­ЪЌЉ№ИЈ ОњОЎОЉОЋОЎ ОаОъОЌОД');
}

