function openLB(src){const ov=document.createElement('div');ov.className='lb';ov.onclick=()=>ov.remove();const btn=document.createElement('button');btn.textContent='РюЋ ОАОњОЋОе';btn.style.cssText='background:rgba(255,255,255,.15);border:none;color:#fff;border-radius:8px;padding:6px 14px;font-size:.8rem;font-weight:700;cursor:pointer;font-family:inherit;';btn.onclick=()=>ov.remove();const img=document.createElement('img');img.src=src;img.onclick=e=>e.stopPropagation();ov.appendChild(btn);ov.appendChild(img);document.body.appendChild(ov);}

function openDraw(src,cb){
  drawCb=cb;const ov=document.getElementById('draw-ov');ov.classList.add('show');
  const cv=document.getElementById('draw-cv');dCtx=cv.getContext('2d');dHist=[];
  const img=new Image();img.onload=()=>{const mw=Math.min(window.innerWidth-24,560);const sc=img.width>mw?mw/img.width:1;cv.width=img.width*sc;cv.height=img.height*sc;dCtx.drawImage(img,0,0,cv.width,cv.height);dCtx.strokeStyle=drawColor;dCtx.lineWidth=drawSz;dCtx.lineCap='round';};img.src=src;
  const cd=document.getElementById('dcols');cd.innerHTML='';
  ['#ef4444','#f59e0b','#22c55e','#3b82f6','#a855f7','#fff','#000'].forEach(c=>{const b=document.createElement('button');b.className='dcol'+(c===drawColor?' on':'');b.style.background=c;b.onclick=()=>{drawColor=c;dCtx.strokeStyle=c;dCtx.fillStyle=c;cd.querySelectorAll('.dcol').forEach(x=>x.classList.remove('on'));b.classList.add('on');};cd.appendChild(b);});
  const td=document.getElementById('dtools');td.innerHTML='';
  [['РюЈ№ИЈ','pen'],['РєЌ№ИЈ','arrow'],['Ргю','rect'],['РГЋ','circle'],['T','text'],['РєЕ№ИЈ','undo']].forEach(([l,m])=>{const b=document.createElement('button');b.className='dtool'+(m===drawMode?' on':'');b.textContent=l;b.onclick=()=>{if(m==='undo'){if(dHist.length)dCtx.putImageData(dHist.pop(),0,0);return;}drawMode=m;td.querySelectorAll('.dtool').forEach(x=>x.classList.remove('on'));b.classList.add('on');};td.appendChild(b);});
  document.getElementById('dsz').oninput=e=>{drawSz=+e.target.value;dCtx.lineWidth=drawSz;};
  document.getElementById('dsave').onclick=()=>{if(drawCb)drawCb(cv.toDataURL('image/jpeg',.88));closeDraw();};
  let dr=false,sx=0,sy=0,sn;
  const gp=e=>{const r=cv.getBoundingClientRect();const t=e.touches?e.touches[0]:e;return{x:(t.clientX-r.left)*(cv.width/r.width),y:(t.clientY-r.top)*(cv.height/r.height)};};
  cv.onmousedown=cv.ontouchstart=e=>{e.preventDefault();dr=true;const p=gp(e);sx=p.x;sy=p.y;dHist.push(dCtx.getImageData(0,0,cv.width,cv.height));sn=dCtx.getImageData(0,0,cv.width,cv.height);if(drawMode==='pen'){dCtx.beginPath();dCtx.moveTo(p.x,p.y);}if(drawMode==='text'){const t=prompt('ОўОДОАОў:');if(t){dCtx.font='bold '+(drawSz*4+10)+'px sans-serif';dCtx.fillStyle=drawColor;dCtx.fillText(t,p.x,p.y);}dr=false;}};
  cv.onmousemove=cv.ontouchmove=e=>{if(!dr||drawMode==='text')return;e.preventDefault();const p=gp(e);dCtx.strokeStyle=drawColor;dCtx.lineWidth=drawSz;if(drawMode==='pen'){dCtx.lineTo(p.x,p.y);dCtx.stroke();}else{dCtx.putImageData(sn,0,0);dCtx.beginPath();if(drawMode==='rect')dCtx.strokeRect(sx,sy,p.x-sx,p.y-sy);if(drawMode==='circle'){const rx=(p.x-sx)/2,ry=(p.y-sy)/2;dCtx.ellipse(sx+rx,sy+ry,Math.abs(rx),Math.abs(ry),0,0,2*Math.PI);dCtx.stroke();}if(drawMode==='arrow'){dCtx.moveTo(sx,sy);dCtx.lineTo(p.x,p.y);dCtx.stroke();const a=Math.atan2(p.y-sy,p.x-sx),l=14;dCtx.beginPath();dCtx.moveTo(p.x,p.y);dCtx.lineTo(p.x-l*Math.cos(a-.4),p.y-l*Math.sin(a-.4));dCtx.moveTo(p.x,p.y);dCtx.lineTo(p.x-l*Math.cos(a+.4),p.y-l*Math.sin(a+.4));dCtx.stroke();}}};
  cv.onmouseup=cv.ontouchend=()=>dr=false;
}

