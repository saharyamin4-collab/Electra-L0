    <div class="sett-grp">
      <div class="si" onclick="openSub('appearance')"><div class="si-l"><div class="si-ico" style="background:linear-gradient(135deg,#0ea5e9,#0369a1);">­Ъје</div><div><div class="si-t">ОъОеОљОћ ОЋОбОЎОдОЋОЉ</div><div class="si-d">ОдОЉОбОЎОЮ ┬и ОњОЋОцОЪ ┬и ОњОЋОЊОю</div></div></div><div class="si-r"><svg class="chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></div></div>
      <div class="si" onclick="openSub('accessibility')"><div class="si-l"><div class="si-ico" style="background:linear-gradient(135deg,#10b981,#047857);">РЎ┐</div><div><div class="si-t">ОаОњОЎОЕОЋОф</div><div class="si-d">ОњОЋОцОЪ, ОаОЎОњОЋОЊОЎОЋОф, ОљОаОЎОъОдОЎОЋОф</div></div></div><div class="si-r"><svg class="chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></div></div>
    </div>
