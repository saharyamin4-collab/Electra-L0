// РЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљ
function loadHome(){if(homeRef){homeRef.off();homeRef=null;}homeRef=db.ref('checklists');homeRef.on('value',s=>{allCls={};const v=s.val()||{};Object.keys(v).forEach(id=>{if(v[id].meta)allCls[id]=v[id].meta;});renderHome();});}
function setF(btn,f){homeF=f;document.querySelectorAll('.chip').forEach(b=>b.classList.remove('on'));btn.classList.add('on');renderHome();}
function showSort(){
  const ov=document.createElement('div');ov.className='modal-bg show';ov.onclick=e=>{if(e.target===ov)ov.remove();};
  const sh=document.createElement('div');sh.className='msheet';
  const modes=[['newest','ОЌОЊОЕ ОюОЎОЕОЪ'],['oldest','ОЎОЕОЪ ОюОЌОЊОЕ'],['name','ОЕОЮ'],['status','ОАОўОўОЋОА'],['progress','ОћОфОДОЊОъОЋОф'],['issues','Issues ОцОфОЋОЌОЎОЮ']];
  sh.innerHTML='<div class="mhandle"></div><div style="font-size:.88rem;font-weight:800;color:var(--t1);margin-bottom:12px;">ОъОЎОЎОЪ ОюОцОЎ</div>'+
    modes.map(([m,l])=>'<button onclick="sortMode=\''+m+'\';this.closest(\'.modal-bg\').remove();renderHome();" style="width:100%;background:'+(sortMode===m?'rgba(41,121,255,.08)':'')+';color:'+(sortMode===m?'var(--blue-accent)':'var(--t2)')+';border:none;padding:12px;border-radius:var(--r3);font-size:.84rem;font-weight:'+(sortMode===m?'800':'600')+';cursor:pointer;font-family:inherit;text-align:right;margin-bottom:4px;border-radius:10px;">'+l+'</button>').join('');
  ov.appendChild(sh);document.body.appendChild(ov);
}
function renderHome(){
  const q=(document.getElementById('home-q')?.value||'').toLowerCase();
  let ids=Object.keys(allCls);
  if(homeF==='in-progress')ids=ids.filter(id=>allCls[id].status==='in-progress');
  else if(homeF==='completed')ids=ids.filter(id=>allCls[id].status==='completed');
  else if(homeF==='not-started')ids=ids.filter(id=>allCls[id].status==='not-started');
  else if(homeF==='open-issues')ids=ids.filter(id=>(allCls[id].openIssues||0)>0);
  else if(homeF==='waiting')ids=ids.filter(id=>(allCls[id].waitingIssues||0)>0);
  if(sortMode==='oldest')ids.sort((a,b)=>a.localeCompare(b));
  else if(sortMode==='name')ids.sort((a,b)=>(allCls[a].title||'').localeCompare(allCls[b].title||''));
  else if(sortMode==='status'){const o={completed:0,'in-progress':1,'not-started':2};ids.sort((a,b)=>(o[allCls[a].status]||2)-(o[allCls[b].status]||2));}
  else if(sortMode==='progress')ids.sort((a,b)=>((allCls[b].passed||0)+(allCls[b].failed||0))-((allCls[a].passed||0)+(allCls[a].failed||0)));
  else if(sortMode==='issues')ids.sort((a,b)=>(allCls[b].openIssues||0)-(allCls[a].openIssues||0));
  else ids.sort((a,b)=>b.localeCompare(a));
  const fil=ids.filter(id=>[allCls[id].title,allCls[id].proj,allCls[id].insp,allCls[id].loc].some(v=>(v||'').toLowerCase().includes(q)));
  const all=Object.keys(allCls);
  document.getElementById('st-tot').textContent=all.length;
  document.getElementById('st-ip').textContent=all.filter(id=>allCls[id].status==='in-progress').length;
  document.getElementById('st-dn').textContent=all.filter(id=>allCls[id].status==='completed').length;
  const hc=document.getElementById('home-count');if(hc)hc.textContent=fil.length?fil.length+" Од'ОДОюОЎОАОўОЎОЮ":'';
  const list=document.getElementById('home-list');list.innerHTML='';
  if(!fil.length){list.innerHTML='<div class="empty"><div class="empty-ico">­ЪЊІ</div><div class="empty-t">ОљОЎОЪ Од\'ОДОюОЎОАОўОЎОЮ</div><div class="empty-s">ОюОЌОЦ ОбОю "ОцОфОЌ Од\'ОДОюОЎОАОў ОЌОЊОЕ" ОюОъОбОюОћ</div></div>';return;}
  fil.forEach(id=>{
    const cl=allCls[id];
    const[sbg,sc,sl]=cl.status==='completed'?['var(--ok-d)','var(--ok)','ОћОЋОЕОюОЮ РюЊ']:cl.status==='in-progress'?['var(--warn-d)','var(--warn)','ОЉОфОћОюОЎОџ']:['rgba(6,16,30,.05)','var(--t3)','ОюОљ ОћОфОЌОЎОю'];
    const stripe=cl.status==='completed'?'var(--ok)':cl.status==='in-progress'?'var(--warn)':'rgba(6,16,30,.1)';
    const p=cl.passed||0,f=cl.failed||0,tot=cl.total||31,na=cl.na||0,eff=Math.max(tot-na,1),pct=Math.round(p/eff*100);
    const oi=cl.openIssues||0,ci=cl.closedIssues||0,wi=cl.waitingIssues||0;
