function recordLogin(){
  try{
    const ua=navigator.userAgent;
    const device=ua.includes('iPhone')?'­ЪЊ▒ iPhone':ua.includes('iPad')?'­ЪЊ▒ iPad':ua.includes('Android')?'­ЪЊ▒ Android':ua.includes('Mac')?'­Ъњ╗ Mac':ua.includes('Windows')?'­ЪќЦ№ИЈ Windows':'­Ъїљ Browser';
    const entry={device,ts:Date.now(),time:new Date().toLocaleString('he-IL'),ip:'Рђћ'};
    let hist=[];try{const s=localStorage.getItem('cx_login_hist');if(s)hist=JSON.parse(s);}catch(e){}
    hist.unshift(entry);if(hist.length>20)hist=hist.slice(0,20);
    localStorage.setItem('cx_login_hist',JSON.stringify(hist));
  }catch(e){}
}
