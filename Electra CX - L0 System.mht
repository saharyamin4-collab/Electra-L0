function closeIssuePage(){
  const pg=document.getElementById('iss-page');
  if(!pg)return;
  // If we were viewing a single issue and there's a parent itemId, go back to item list
  const fromItem=pg.dataset.fromItem;
  pg.classList.remove('open');
  if(fromItem){
    delete pg.dataset.fromItem;
    setTimeout(()=>openItemIssuesPage(parseInt(fromItem)),50);
    return;
  }
  schedSave();
}

function syncIssField(prefix,itemId,idx,val){
  const el=document.getElementById(prefix+'-'+itemId+'-'+idx);if(el)el.value=val;
  schedSave();
}
function syncIssPageSt(itemId,idx){
  const pgBtn=document.getElementById('ipst-'+itemId+'-'+idx);
  const clBtn=document.getElementById('ist-'+itemId+'-'+idx);
  if(pgBtn&&clBtn){
    pgBtn.className='iss-st '+clBtn.className.replace('iss-st ','').replace(' ip-st-btn','')+' ip-st-btn';
    pgBtn.dataset.s=clBtn.dataset.s;pgBtn.textContent=clBtn.textContent;
  }
  // Hide waiting button if no longer open
  const wBtn=document.querySelector('#iss-page-body .wait-btn');
  if(wBtn)wBtn.style.display=(clBtn?.dataset.s==='open'?'':'none');
}
function syncIssPageCats(itemId,idx){
  const pageCats=[...document.querySelectorAll('#iss-page-body .cpill.sel')].map(b=>b.textContent);
  const clPills=document.querySelectorAll('#cpills-'+itemId+'-'+idx+' .cpill');
  clPills.forEach(b=>{b.classList.toggle('sel',pageCats.includes(b.textContent));});
  schedSave();
}
function setPrioPage(itemId,idx,prio,btn){
  if(!issuePriority[itemId])issuePriority[itemId]={};
  issuePriority[itemId][idx]=prio;
  // Update ip-prio-btn active state in the issue page
  const row=btn.closest('.ip-prio-row');
  if(row){
    row.querySelectorAll('.ip-prio-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
  }
  // Also sync the hidden iss-block prio buttons if they exist
  const old_row=document.querySelector('#ib-'+itemId+'-'+idx+' .prio-sel');
  if(old_row){old_row.querySelectorAll('.prio-btn').forEach(b=>b.className='prio-btn');old_row.querySelector('.prio-btn:nth-child('+(prio==='high'?1:prio==='med'?2:3)+')')?.classList.add(prio==='high'?'sel-h':prio==='med'?'sel-m':'sel-l');}
  schedSave();
}
function syncIssPhotosToPage(itemId,idx){
  const row=document.getElementById('iph-page-'+itemId+'-'+idx);if(!row)return;
  row.innerHTML='';
  (issuePhotos[itemId]?.[idx]||[]).filter(p=>p?.url).forEach((p,pi)=>{
    const t=mkThumb(p.url,itemId,idx,'iss');t.dataset.pi=pi;row.appendChild(t);
  });
}
function pickIssContact(itemId,idx,name,email){
  // Update hidden fields
  syncIssField('ip',itemId,idx,name);
  syncIssField('ie',itemId,idx,email);
  // Update visible page inputs
  const pInp=document.getElementById('ipp-'+itemId+'-'+idx);if(pInp)pInp.value=name;
  const eInp=document.getElementById('iep-'+itemId+'-'+idx);if(eInp)eInp.value=email;
  // Highlight selected pill
  document.querySelectorAll('#icp-'+itemId+'-'+idx+' .contact-pill').forEach(b=>{
    b.classList.toggle('sel',b.textContent.includes(name));
  });
  schedSave();
}
function setPrio(itemId,idx,prio,btn){
  if(!issuePriority[itemId])issuePriority[itemId]={};issuePriority[itemId][idx]=prio;
  const row=btn.closest('.prio-sel');if(row){row.querySelectorAll('.prio-btn').forEach(b=>b.className='prio-btn');btn.classList.add(prio==='high'?'sel-h':prio==='med'?'sel-m':'sel-l');}
  schedSave();
}

function delIss(itemId,idx){
  document.getElementById('ib-'+itemId+'-'+idx)?.remove();
  const cont=document.getElementById('iss'+itemId);
  if(!cont?.children.length){document.getElementById('isb'+itemId)?.classList.remove('hot');}
  updIssBar();schedSave();
}

function addIssPhoto(inp,itemId,idx){
  if(!inp.files?.length)return;
  if(!issuePhotos[itemId])issuePhotos[itemId]={};
  if(!issuePhotos[itemId][idx])issuePhotos[itemId][idx]=[];
  const row=document.getElementById('ibp-'+itemId+'-'+idx);
  [...inp.files].forEach(f=>{const r=new FileReader();r.onload=e=>{const img=new Image();img.onload=()=>{const c=document.createElement('canvas');const sc=Math.min(1,600/img.width);c.width=img.width*sc;c.height=img.height*sc;c.getContext('2d').drawImage(img,0,0,c.width,c.height);const b64=c.toDataURL('image/jpeg',.7);issuePhotos[itemId][idx].push({url:b64});row.appendChild(mkThumb(b64,itemId,idx,'iss'));schedSave();};img.src=e.target.result;};r.readAsDataURL(f);});inp.value='';
}

function mkCPills(itemId,idx){
  const div=document.getElementById('cp-'+itemId+'-'+idx);if(!div||!contacts.length)return;div.innerHTML='';
  contacts.filter(c=>c.name).forEach(c=>{const b=document.createElement('button');b.className='cpill';b.textContent=c.name;b.onclick=()=>{if(!isAuthed){toast('­Ъћњ ОаОЊОеОЕОф ОћОеОЕОљОћ');return;}document.getElementById('ip-'+itemId+'-'+idx).value=c.name;document.getElementById('ie-'+itemId+'-'+idx).value=c.email||'';div.querySelectorAll('.cpill').forEach(x=>x.classList.remove('sel'));b.classList.add('sel');schedSave();};div.appendChild(b);});
}

function createIss(itemId,idx){
  if(!isAuthed){toast('­Ъћњ ОаОЊОеОЕОф ОћОеОЕОљОћ');return;}
  const person=document.getElementById('ip-'+itemId+'-'+idx)?.value||'';
  const email=document.getElementById('ie-'+itemId+'-'+idx)?.value||'';
  const desc=document.getElementById('id-'+itemId+'-'+idx)?.value||'';
  const action=document.getElementById('iact-'+itemId+'-'+idx)?.value||'';
  const panel=document.getElementById('f-panel')?.value||'ОюОљ ОдОЋОЎОЪ';
  const insp=document.getElementById('f-insp')?.value||'ОЉОЋОЊОД';
  const proj=document.getElementById('f-proj')?.value||'';
  const fdate=document.getElementById('f-date')?.value||new Date().toLocaleDateString('he-IL');
  const sec=ITEMS.find(x=>x.id===itemId)?.t||'ОАОбОЎОБ '+itemId;
  const prio=issuePriority[itemId]?.[idx]||'med';
  const prioTxt=prio==='high'?'­Ъћ┤ ОњОЉОЋОћОћ':prio==='med'?'­ЪЪА ОЉОЎОаОЋОаОЎОф':'­ЪЪб ОаОъОЋОЏОћ';
  if(!desc.trim()){toast('Рџа№ИЈ ОљОаОљ ОъОюОљ ОцОЎОеОЋОў ОюОЎОДОЋОЎ');return;}
  if(!email){toast('Рџа№ИЈ ОљОаОљ ОћОќОЪ ОъОЎОЎОю ОљОЌОеОљОЎ');return;}
  const sub=encodeURIComponent('[Electra CX L0] ОюОЎОДОЋОЎ '+prioTxt+' Рђћ ОАОбОЎОБ '+itemId+' | '+panel);
