@charset "utf-8";

:root { --slate-900: #0f172a; --slate-800: #1e293b; --electra-blue: #00458e; --gold: #d4af37; --bg: #f8fafc; --border: #e2e8f0; --passed: #10b981; --failed: #ef4444; --na: #94a3b8; }

body { font-family: system-ui, -apple-system, sans-serif; background: var(--bg); margin: 0px; padding: 16px; color: var(--slate-900); -webkit-font-smoothing: antialiased; }

.app-frame { max-width: 600px; margin: 0px auto; }

.premium-header { background: linear-gradient(135deg, var(--slate-900), var(--slate-800)); color: white; padding: 25px 20px; border-radius: 16px; text-align: center; box-shadow: rgba(15, 23, 42, 0.15) 0px 20px 25px -5px; margin-bottom: 20px; border-bottom: 3px solid var(--gold); }

.brand-title { font-size: 1.8rem; font-weight: 900; margin: 0px; }

.brand-title span { color: var(--gold); }

.brand-subtitle { margin: 6px 0px 0px; font-size: 0.95rem; font-weight: 700; color: rgb(226, 232, 240); }

.card { background: white; border-radius: 16px; padding: 20px; margin-bottom: 16px; box-shadow: rgba(0, 0, 0, 0.02) 0px 4px 6px -1px; border: 1px solid var(--border); }

.card h2 { margin: 0px 0px 16px; font-size: 1.1rem; font-weight: 800; display: flex; align-items: center; gap: 8px; }

.card h2::before { content: ""; display: inline-block; width: 4px; height: 16px; background: var(--gold); border-radius: 2px; }

.field { display: flex; flex-direction: column; gap: 4px; margin-bottom: 12px; }

.field label { font-size: 0.8rem; font-weight: 700; color: rgb(100, 116, 139); text-transform: uppercase; }

.field input, .quick-note, .issue-input, textarea, .inline-date-picker { padding: 12px; border: 1px solid var(--border); border-radius: 10px; font-size: 0.95rem; background: rgb(248, 250, 252); outline: none; width: 100%; box-sizing: border-box; }

.inline-date-picker { font-family: inherit; margin-top: 4px; border: 1px solid rgb(203, 213, 225); background: rgb(255, 255, 255); max-width: 200px; display: block; cursor: pointer; }

.quick-note { height: 40px; resize: none; margin-bottom: 8px; }

.issue-input { font-size: 0.85rem; padding: 8px; margin-bottom: 6px; }

.global-status-selector { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-top: 10px; margin-bottom: 10px; }

.g-btn { padding: 10px; border: 1px solid var(--border); background: rgb(241, 245, 249); border-radius: 8px; font-weight: bold; cursor: pointer; text-align: center; font-size: 0.85rem; color: var(--slate-800); }

.g-btn.active { color: white; }

.g-btn.not-started.active { background: rgb(100, 116, 139); border-color: rgb(100, 116, 139); }

.g-btn.in-progress.active { background: rgb(245, 158, 11); border-color: rgb(245, 158, 11); }

.g-btn.completed.active { background: rgb(16, 185, 129); border-color: rgb(16, 185, 129); }

.banner { background: rgb(241, 245, 249); padding: 12px; font-weight: 800; font-size: 0.95rem; border-radius: 10px; margin: 20px 0px 10px; border-right: 4px solid var(--slate-900); }

.item { background: white; border-radius: 16px; padding: 16px; margin-bottom: 12px; border: 1px solid var(--border); }

.item-header-row { display: flex; justify-content: space-between; align-items: center; gap: 15px; margin-bottom: 12px; width: 100%; box-sizing: border-box; }

.item-text { font-size: 0.95rem; font-weight: 600; line-height: 1.4; color: var(--slate-800); flex-grow: 1; }

.issue-trigger-btn { background: rgb(241, 245, 249); color: var(--slate-800); border: 1px solid var(--border); padding: 6px 14px; border-radius: 6px; font-size: 0.75rem; font-weight: 800; cursor: pointer; flex-shrink: 0; letter-spacing: 0.5px; transition: 0.2s; }

.issue-trigger-btn.has-issue { background: rgb(254, 202, 202); color: rgb(220, 38, 38); border-color: rgb(248, 113, 113); box-shadow: rgba(220, 38, 38, 0.08) 0px 2px 4px; }

.btn-gp { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-bottom: 10px; }

.btn-s { padding: 10px; border: 1px solid var(--border); background: white; border-radius: 8px; font-weight: 700; font-size: 0.8rem; cursor: pointer; color: rgb(100, 116, 139); text-align: center; }

.btn-s.p.active { background: rgb(236, 253, 245); color: var(--passed); border-color: var(--passed); }

.btn-s.f.active { background: rgb(254, 242, 242); color: var(--failed); border-color: var(--failed); }

.btn-s.n.active { background: rgb(226, 232, 240); color: var(--slate-800); border-color: var(--na); }

.issue-sliding-panel { display: none; background: rgb(255, 251, 251); border: 1px dashed rgb(252, 165, 165); border-radius: 12px; padding: 14px; margin-top: 10px; }

.btn-a { background: var(--slate-800); color: white; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 8px 14px; border-radius: 8px; font-size: 0.8rem; font-weight: 700; cursor: pointer; }

.btn-a.mail { background: rgb(37, 99, 235); width: 100%; margin-bottom: 8px; margin-top: 6px; }

.btn-a.mail:disabled { cursor: not-allowed; border: 1px solid rgb(226, 232, 240); background: rgb(203, 213, 225) !important; color: rgb(148, 163, 184) !important; }

.btn-a.del { background: rgb(254, 226, 226); color: var(--failed); margin-top: 8px; }

.can-wrap { position: relative; margin-top: 10px; background: rgb(241, 245, 249); border-radius: 12px; display: inline-block; max-width: 100%; overflow: hidden; border: 1px solid var(--border); }

canvas { display: block; max-width: 100%; background: white; }

.sig-box { border: 1px solid var(--border); border-radius: 12px; background: rgb(248, 250, 252); margin-top: 6px; height: 110px; }

.sub-bar { background: linear-gradient(135deg, var(--slate-900), var(--slate-800)); color: white; width: 100%; border-top-width: medium; border-right-width: medium; border-left-width: medium; border-top-style: none; border-right-style: none; border-left-style: none; border-top-color: currentcolor; border-right-color: currentcolor; border-left-color: currentcolor; border-image: initial; padding: 18px; font-size: 1.15rem; font-weight: 800; border-radius: 14px; cursor: pointer; margin: 30px 0px; border-bottom: 3px solid var(--gold); box-shadow: rgba(15, 23, 42, 0.15) 0px 10px 25px; }

.summary-list { font-size: 0.85rem; padding-right: 20px; color: var(--failed); font-weight: bold; }

.summary-list li { margin-bottom: 4px; cursor: pointer; text-decoration: underline; }
