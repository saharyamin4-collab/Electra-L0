function collect(){
  const data={v:11,ts:Date.now(),status:STATUS,panel:document.getElementById('f-panel')?.value||'',pnum:document.getElementById('f-num')?.value||'',proj:document.getElementById('f-proj')?.value||'',loc:document.getElementById('f-loc')?.value||'',insp:document.getElementById('f-insp')?.value||'',mfr:document.getElementById('f-mfr')?.value||'',fdate:document.getElementById('f-date')?.value||'',notes:document.getElementById('f-notes')?.value||'',sigs:[],items:{},actLog,priority:issuePriority};
  for(let i=0;i<5;i++){const e=document.getElementById('sig'+i);data.sigs.push(e?e.value:'');}
  for(let i=1;i<=31;i++){
    const el=document.getElementById('ic'+i);if(!el)continue;
    let s='X';if(el.querySelector('.pfn.p.on'))s='P';else if(el.querySelector('.pfn.f.on'))s='F';else if(el.querySelector('.pfn.n.on'))s='N';
    const note=document.getElementById('note'+i)?.value||'';
    const issues=[];
    const cont=document.getElementById('iss'+i);
    if(cont){cont.querySelectorAll('.iss-block').forEach((bl,bi)=>{const n=bi+1;const st=document.getElementById('ist-'+i+'-'+n)?.dataset.s||'open';const prio=issuePriority[i]?.[n]||'med';const photos=(issuePhotos[i]?.[n]||[]).filter(p=>p&&(p.url||typeof p==='string')).map(p=>typeof p==='string'?{url:p}:p);const confirmed=bl.dataset.confirmed==='1';issues.push({person:document.getElementById('ip-'+i+'-'+n)?.value||'',email:document.getElementById('ie-'+i+'-'+n)?.value||'',desc:document.getElementById('id-'+i+'-'+n)?.value||'',action:document.getElementById('iact-'+i+'-'+n)?.value||'',status:st,priority:prio,photos,confirmed});});}
    data.items['i'+i]={s,note,issues};
  }
  return data;
}

function apply(data){
  if(!data)return;
  setSt(data.status||'not-started');
  const set=(id,v)=>{const e=document.getElementById(id);if(e&&v!==undefined)e.value=v;};
  set('f-panel',data.panel);syncName();set('f-num',data.pnum);set('f-proj',data.proj);set('f-loc',data.loc);set('f-insp',data.insp);set('f-mfr',data.mfr);set('f-date',data.fdate);set('f-notes',data.notes);
  if(data.sigs)data.sigs.forEach((v,i)=>set('sig'+i,v));
  if(data.actLog&&data.actLog.length>actLog.length)actLog=data.actLog;
  if(data.priority)Object.assign(issuePriority,data.priority);
  for(let i=1;i<=31;i++){
    const item=data.items?.['i'+i];if(!item)continue;
    const el=document.getElementById('ic'+i);if(!el)continue;
    el.querySelectorAll('.pfn').forEach(b=>b.classList.remove('on'));el.classList.remove('p','f','n');
    if(item.s==='P'){el.querySelector('.pfn.p')?.classList.add('on');el.classList.add('p');}
    else if(item.s==='F'){el.querySelector('.pfn.f')?.classList.add('on');el.classList.add('f');}
    else if(item.s==='N'){el.querySelector('.pfn.n')?.classList.add('on');el.classList.add('n');}
    set('note'+i,item.note||'');if((item.note||'').trim())noteChg(i);
    // Clear existing issues before re-rendering to prevent duplicates on every Firebase update
    const cont=document.getElementById('iss'+i);if(cont){cont.innerHTML='';issueCnt[i]=0;}
    const isp=document.getElementById('isp'+i);if(isp)isp.style.display='none';
    document.getElementById('isb'+i)?.classList.remove('hot');
    if(item.issues?.length)item.issues.forEach(iss=>{if(iss)addIss(i,iss);});
  }
  updIssBar();updHeroProg();applyAuthState();
  for(let i=1;i<=31;i++){(id=>{db.ref('checklists/'+CID+'/photos/item'+id).once('value').then(s=>{const ph=s.val();if(!ph)return;const arr=Array.isArray(ph)?ph:Object.values(ph);itemPhotos[id]=arr;const row=document.getElementById('pt'+id);if(row)arr.forEach((p,idx)=>{if(p?.url&&!document.getElementById('th-'+id+'-'+idx)){const t=mkThumb(p.url,id,idx,'item');t.id='th-'+id+'-'+idx;row.appendChild(t);}});updCB(id);}).catch(()=>{})})(i);}
}

function updMetaFor(id,data){
  let p=0,f=0,na=0,open=0,closed=0,waiting=0;
  for(let i=1;i<=31;i++){const d=data.items?.['i'+i];if(!d)continue;if(d.s==='P')p++;else if(d.s==='F')f++;else if(d.s==='N')na++;if(d.issues)d.issues.forEach(iss=>{if(!iss?.desc)return;if(iss.status==='closed')closed++;else if(iss.status==='waiting')waiting++;else open++;});}
  const ex=allCls[id]||{};
  const meta={title:data.panel||ex.title||'ОюОюОљ ОЕОЮ',proj:data.proj||'',insp:data.insp||'',fdate:data.fdate||'',status:data.status||'not-started',passed:p,failed:f,na,total:31,openIssues:open,closedIssues:closed,waitingIssues:waiting,created:ex.created||new Date().toLocaleDateString('he-IL'),updated:new Date().toLocaleDateString('he-IL')};
  db.ref('checklists/'+id+'/meta').set(meta).catch(()=>{});allCls[id]=meta;
}
function updMeta(data){updMetaFor(CID,data);}

function resetCl(){
  for(let i=1;i<=31;i++){
    const el=document.getElementById('ic'+i);if(!el)continue;
    el.querySelectorAll('.pfn').forEach(b=>b.classList.remove('on'));el.classList.remove('p','f','n');
    const n=document.getElementById('note'+i);if(n)n.value='';
    const np=document.getElementById('np'+i);if(np)np.style.display='none';
    document.getElementById('ni'+i)?.setAttribute('stroke','#94a3b8');
    const nd=document.getElementById('nd'+i);if(nd)nd.style.display='none';
    const cont=document.getElementById('iss'+i);if(cont){cont.innerHTML='';issueCnt[i]=0;}
    const isp=document.getElementById('isp'+i);if(isp)isp.style.display='none';
    document.getElementById('isb'+i)?.classList.remove('hot');
    const pt=document.getElementById('pt'+i);if(pt)pt.innerHTML='';
    updCB(i);
    const pp=document.getElementById('pp'+i);if(pp)pp.style.display='none';
  }
  itemPhotos={};issuePhotos={};actLog=[];issuePriority={};
  ['f-panel','f-num','f-proj','f-loc','f-insp','f-mfr','f-date','f-notes'].forEach(id=>{const e=document.getElementById(id);if(e)e.value='';});
  for(let i=0;i<5;i++){const e=document.getElementById('sig'+i);if(e)e.value='';}
  setSt('not-started');updIssBar();updHeroProg();
  const d=document.getElementById('cl-name');if(d)d.textContent="Од'ОДОюОЎОАОў ОЌОЊОЕ";
  const sub=document.getElementById('cl-sub');if(sub)sub.textContent='';
}

function addIss(itemId,data={}){
  const cont=document.getElementById('iss'+itemId);if(!cont)return;
  if(!issueCnt[itemId])issueCnt[itemId]=0;
  issueCnt[itemId]++;
  const idx=issueCnt[itemId];
  const st=data.status||'open';
  const prio=data.priority||data.prio||'med';
  if(!issuePriority[itemId])issuePriority[itemId]={};
  issuePriority[itemId][idx]=prio;
  const bl=document.createElement('div');
  bl.className='iss-block'+(st==='closed'?' closed':st==='waiting'?' waiting':'');
  bl.id='ib-'+itemId+'-'+idx;
  if(data.confirmed)bl.dataset.confirmed='1';
  const cats=['ОЌОЎОЉОЋОеОЎОЮ','ОфОЎОбОЋОЊ','ОдОЎОЋОЊ','ОЉОўОЎОЌОЋОф','ОфОДОЕОЋОеОф','ОљОЌОе'];
  const selCats=data.cats||[];
  bl.innerHTML=
    '<div class="iss-top">'+
      '<span class="iss-num">Issue #'+idx+'</span>'+
      '<div style="display:flex;gap:5px;align-items:center;">'+
        '<button class="iss-st '+(st==='closed'?'closed':st==='waiting'?'waiting':'open')+'" id="ist-'+itemId+'-'+idx+'" data-s="'+st+'" onclick="cycleIssStatus('+itemId+','+idx+',this)">'+
          (st==='closed'?'РюЊ ОАОњОЋОе':st==='waiting'?'РЈ│ ОъОъОфОЎОЪ':'Рџа ОцОфОЋОЌ')+
        '</button>'+
        // Delete only for admins
        '<button class="iss-del" id="idel-'+itemId+'-'+idx+'" onclick="requireAuth(()=>delIss('+itemId+','+idx+'))" style="'+(isAuthed?'':'display:none;')+'">РюЋ</button>'+
      '</div>'+
    '</div>'+
    '<div class="prio-sel" id="psel-'+itemId+'-'+idx+'" style="'+(isAuthed?'':'display:none;')+'">'+
      '<button class="prio-btn'+(prio==='high'?' sel-h':'')+'" onclick="requireAuth(()=>setPrio('+itemId+','+idx+',\'high\',this))">­Ъћ┤ ОњОЉОЋОћОћ</button>'+
      '<button class="prio-btn'+(prio==='med'?' sel-m':'')+'" onclick="requireAuth(()=>setPrio('+itemId+','+idx+',\'med\',this))">­ЪЪА ОЉОЎОаОЋОаОЎОф</button>'+
      '<button class="prio-btn'+(prio==='low'?' sel-l':'')+'" onclick="requireAuth(()=>setPrio('+itemId+','+idx+',\'low\',this))">­ЪЪб ОаОъОЋОЏОћ</button>'+
    '</div>'+
    '<div class="cpills" id="cpills-'+itemId+'-'+idx+'" style="'+(isAuthed?'':'display:none;')+'">'+cats.map(c=>'<button class="cpill'+(selCats.includes(c)?' sel':'')+'" onclick="requireAuth(()=>this.classList.toggle(\'sel\'));schedSave();">'+c+'</button>').join('')+'</div>'+
    '<input class="ii" id="ip-'+itemId+'-'+idx+'" placeholder="ОЕОЮ ОљОЌОеОљОЎ..." value="'+(data.person||'')+'" oninput="schedSave();" '+(isAuthed?'':'disabled')+'>'+
    '<input class="ii" id="ie-'+itemId+'-'+idx+'" type="email" placeholder="ОъОЎОЎОю..." value="'+(data.email||'')+'" oninput="schedSave();" '+(isAuthed?'':'disabled')+'>'+
