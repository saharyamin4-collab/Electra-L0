function schedSave(){if(saveT)clearTimeout(saveT);saveT=setTimeout(forceSave,400);}

function confirmIss(itemId,idx){
  if(!isAuthed){toast('­Ъћњ ОаОЊОеОЕОф ОћОеОЕОљОћ');return;}
  const desc=document.getElementById('id-'+itemId+'-'+idx)?.value||'';
  if(!desc.trim()){toast('Рџа№ИЈ ОљОаОљ ОъОюОљ ОцОЎОеОЋОў ОюОЎОДОЋОЎ');return;}
  const bl=document.getElementById('ib-'+itemId+'-'+idx);
  if(bl)bl.dataset.confirmed='1';
  const btn=document.getElementById('cib-'+itemId+'-'+idx);
  if(btn){btn.textContent='РюЁ Issue ОаОЋОдОе';btn.disabled=true;btn.style.background='var(--ok-d)';btn.style.color='var(--ok)';btn.style.borderColor='var(--ok-m)';}
  document.getElementById('isb'+itemId)?.classList.add('hot');
  updIssBar();schedSave();
  toast('РюЁ Issue ОаОЋОАОБ ОюОАОЎОЏОЋОЮ!');
  if(navigator.vibrate)navigator.vibrate([40,20,40]);
}

// РћђРћђРћђРћђ FILE ATTACHMENT РћђРћђРћђРћђ
let itemFiles={};
function addFile(inp,id){
  if(!inp.files?.length)return;
  if(!itemFiles[id])itemFiles[id]=[];
  const list=document.getElementById('fl'+id);
  if(!list)return;
  // Show photo panel if hidden
  const pp=document.getElementById('pp'+id);
  if(pp&&pp.style.display!=='block')pp.style.display='block';
  [...inp.files].forEach(f=>{
    const fobj={name:f.name,size:f.size,type:f.type,dataUrl:''};
    const r=new FileReader();
    r.onload=e=>{
      fobj.dataUrl=e.target.result;
      itemFiles[id].push(fobj);
      const row=document.createElement('div');
      row.className='file-item';
      const isImg=f.type.startsWith('image/');
      row.innerHTML='<span class="file-ico">'+(isImg?'­Ъќ╝№ИЈ':f.type.includes('pdf')?'­ЪЊё':f.type.includes('word')||f.name.endsWith('.docx')?'­ЪЊЮ':'­ЪЊј')+'</span>'+
        '<span class="file-name">'+f.name+'</span>'+
        '<span class="file-sz">'+Math.round(f.size/1024)+'KB</span>'+
        '<button class="file-del" onclick="this.parentElement.remove();itemFiles['+id+']=itemFiles['+id+'].filter(x=>x.name!==\''+f.name+'\');updFB('+id+');schedSave();">РюЋ</button>';
      list.appendChild(row);
      updFB(id);schedSave();
    };
    r.readAsDataURL(f);
  });
  inp.value='';
}

function updFB(id){
  const n=(itemFiles[id]||[]).length;
  const b=document.getElementById('fb'+id);
  const ic=document.getElementById('fi'+id);
  if(b){b.style.display=n?'flex':'none';b.textContent=n||'';}
  if(ic)ic.setAttribute('stroke',n?'var(--blue-accent)':'#94a3b8');
}

function forceSave(){
  if(!CID)return;
  const myId=CID;
  const data=collect();
  saveQueue=data;
  try{localStorage.setItem('cl_'+myId,JSON.stringify(data));}catch(e){}
  if(saveInFlight)return;
  _doSave();
}

function _doSave(){
  if(!saveQueue||!CID)return;
  const myId=CID;
  const data=saveQueue;saveQueue=null;saveInFlight=true;
  const pill=document.getElementById('save-pill');if(pill){pill.textContent='ОЕОЋОъОе...';pill.className='spill saving';}
  const attempt=(n,delay)=>{
    db.ref('checklists/'+myId+'/data').set(data)
      .then(()=>{saveInFlight=false;lastSavedTs=data.ts||0;if(pill){pill.textContent='РюЊ ОаОЕОъОе';pill.className='spill saved';setTimeout(()=>{if(pill){pill.textContent='';pill.className='spill';}},2200);}updMetaFor(myId,data);if(saveQueue&&CID)_doSave();})
      .catch(()=>{if(n>0)setTimeout(()=>attempt(n-1,delay*1.5),delay);else{saveInFlight=false;if(pill){pill.textContent='­ЪњЙ ОъОДОЋОъОЎ';pill.className='spill local';setTimeout(()=>{if(pill){pill.textContent='';pill.className='spill';}},3000);}if(saveQueue&&CID)_doSave();}});
  };
  attempt(4,700);
}

function renderIssues(){
  const q=(document.getElementById('iss-q')?.value||'').toLowerCase();
  const list=document.getElementById('iss-list');list.innerHTML='';let any=false;
  for(let i=1;i<=31;i++){
    const cont=document.getElementById('iss'+i);if(!cont)continue;
    cont.querySelectorAll('.iss-block').forEach((bl,bi)=>{
      if(bl.dataset.confirmed!=='1')return;
      const n=bi+1;
      const desc=document.getElementById('id-'+i+'-'+n)?.value||'';
      const person=document.getElementById('ip-'+i+'-'+n)?.value||'';
      const email=document.getElementById('ie-'+i+'-'+n)?.value||'';
      const action=document.getElementById('iact-'+i+'-'+n)?.value||'';
      const sec=ITEMS.find(x=>x.id===i)?.t||'ОАОбОЎОБ '+i;
      const st=document.getElementById('ist-'+i+'-'+n)?.dataset.s||'open';
      const prio=issuePriority[i]?.[n]||'med';
      if(issF==='open'&&st!=='open')return;
      if(issF==='waiting'&&st!=='waiting')return;
      if(issF==='closed'&&st!=='closed')return;
      if(issF==='high'&&(st==='closed'||prio!=='high'))return;
      if(q&&![desc,person,sec,email,action].some(s=>s.toLowerCase().includes(q)))return;
      any=true;
      const prioLabel=prio==='high'?'<span class="prio-badge pb-h">­Ъћ┤ ОњОЉОЋОћОћ</span>':prio==='low'?'<span class="prio-badge pb-l">­ЪЪб ОаОъОЋОЏОћ</span>':'';
      const stCls=st==='closed'?' closed':st==='waiting'?' waiting':'';
      const stBadge=st==='closed'?'<span class="ich ich-c">РюЊ ОАОњОЋОе</span>':st==='waiting'?'<span class="ich ich-w">РЈ│ ОъОъОфОЎОЪ</span>':'<span class="ich ich-o">Рџа№ИЈ ОцОфОЋОЌ</span>';
      const card=document.createElement('div');card.className='iss-card'+stCls;
      card.onclick=()=>window.open(location.pathname+'?cl='+id,'_blank');
      card.innerHTML='<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:7px;"><div style="display:flex;align-items:center;gap:5px;"><span style="font-size:.64rem;font-weight:700;color:var(--t3);font-family:\'JetBrains Mono\',monospace;">ОАОбОЎОБ '+i+' ┬и #'+n+'</span>'+prioLabel+'</div>'+stBadge+'</div>'+(person?'<div style="font-size:.8rem;font-weight:700;color:var(--navy);margin-bottom:4px;">­ЪЉц '+person+(email?' <span style="font-weight:500;color:var(--t3);font-size:.72rem;">('+email+')</span>':'')+'</div>':'')+'<div style="font-size:.77rem;color:var(--t2);line-height:1.45;margin-bottom:'+(action?'5':'0')+'px;">'+(desc||'<span style="color:var(--t3)">ОюОюОљ ОцОЎОеОЋОў</span>')+'</div>'+(action?'<div style="font-size:.72rem;color:var(--t3);margin-top:4px;">­ЪћД '+action+'</div>':'')+'<div style="font-size:.64rem;color:var(--t3);margin-top:6px;font-family:\'JetBrains Mono\',monospace;">'+sec.substring(0,55)+(sec.length>55?'...':'')+'</div>';
      list.appendChild(card);
    });
  }
  if(!any)list.innerHTML='<div class="empty" style="padding:28px;"><div class="empty-ico" style="font-size:2rem;">РюЁ</div><div class="empty-t">ОљОЎОЪ Issues</div></div>';
}

function setIF(f,btn){issF=f;document.querySelectorAll('[id^=if-]').forEach(b=>b.classList.remove('on'));btn.classList.add('on');renderIssues();}

function renderDash(){
  let p=0,f=0,na=0,open=0,closed=0,waiting=0,unset=0;
  const byCh={2:{p:0,f:0,na:0,tot:0},3:{p:0,f:0,na:0,tot:0},4:{p:0,f:0,na:0,tot:0}};
  const failItems=[],naItems=[],openList=[];
  for(let i=1;i<=31;i++){
    const el=document.getElementById('ic'+i);if(!el)continue;
    const item=ITEMS.find(x=>x.id===i);const ch=item?.c||2;byCh[ch].tot++;
    if(el.querySelector('.pfn.p.on')){p++;byCh[ch].p++;}
    else if(el.querySelector('.pfn.f.on')){f++;byCh[ch].f++;failItems.push(i);}
    else if(el.querySelector('.pfn.n.on')){na++;byCh[ch].na++;naItems.push(i);}
    else unset++;
