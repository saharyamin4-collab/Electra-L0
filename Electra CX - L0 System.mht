<style>
/* РЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљ
   ELECTRA CX Рђћ DESIGN SYSTEM v3
   Industrial precision meets mobile-first UX
РЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљ */
:root{
  /* Core palette Рђћ dark navy + electric gold accent */
  --bg-deep:#05111f;
  --bg-mid:#091a2e;
  --bg-card:#0d2240;
  --blue-accent:#2979ff;
  --gold:#f59e0b;
  --gold2:#fbbf24;
  --gold-glow:rgba(245,158,11,.15);
  --ok:#22c55e;--ok-d:rgba(34,197,94,.12);--ok-m:rgba(34,197,94,.22);
  --warn:#f97316;--warn-d:rgba(249,115,22,.12);
  --fail:#ef4444;--fail-d:rgba(239,68,68,.12);--fail-m:rgba(239,68,68,.22);
  --purple:#a855f7;--purple-d:rgba(168,85,247,.12);--purple-m:rgba(168,85,247,.22);

  /* Light surface (cards in checklist) */
  --surf:#f0f4f8;--surf2:#e2e8f0;
  --card:#ffffff;--card2:#f8fafc;
  --border:rgba(6,16,30,.07);--border2:rgba(6,16,30,.13);
  --t1:#0f172a;--t2:#334155;--t3:#64748b;--t4:#94a3b8;

  /* Geometry */
  --r:18px;--r2:13px;--r3:10px;--r4:7px;
  --sh:0 1px 3px rgba(6,16,30,.06),0 4px 16px rgba(6,16,30,.08);
  --sh2:0 8px 28px rgba(6,16,30,.16);--sh3:0 20px 60px rgba(6,16,30,.28);

  /* Layout */
  --nav-h:56px;--tab-h:68px;
  --safe-t:env(safe-area-inset-top,0px);
  --safe-b:env(safe-area-inset-bottom,0px);
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html{height:100%;text-size-adjust:none;}
body{height:100%;font-family:'Heebo','Inter',system-ui,sans-serif;background:var(--surf);color:var(--t1);-webkit-font-smoothing:antialiased;overscroll-behavior:none;-webkit-overflow-scrolling:touch;}

/* РћђРћђ APP SHELL РћђРћђ */
#app{display:flex;flex-direction:column;height:100%;max-width:430px;margin:0 auto;position:relative;box-shadow:0 0 60px rgba(0,0,0,.25);}

/* РћђРћђ NAVBAR РћђРћђ */
.nav{background:var(--bg-deep);height:calc(var(--nav-h)+var(--safe-t));padding-top:var(--safe-t);display:flex;align-items:center;justify-content:space-between;padding-left:16px;padding-right:16px;flex-shrink:0;position:relative;z-index:300;}
.nav::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(245,158,11,.3),transparent);}
.nav-logo-wrap{display:flex;align-items:center;gap:8px;}
.nav-bolt{width:28px;height:28px;background:linear-gradient(135deg,var(--gold),var(--gold2));border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:.85rem;box-shadow:0 0 12px var(--gold-glow);}
.nav-brand{display:flex;flex-direction:column;line-height:1.1;}
.nav-name{font-size:.7rem;font-weight:900;letter-spacing:2.5px;color:#fff;text-transform:uppercase;}
.nav-sub{font-size:.52rem;color:rgba(255,255,255,.35);letter-spacing:1px;text-transform:uppercase;}
.nav-r{display:flex;gap:6px;align-items:center;}
.nav-back{display:flex;align-items:center;gap:6px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.85);border-radius:var(--r4);padding:7px 12px;font-size:.75rem;font-weight:700;cursor:pointer;font-family:inherit;transition:all .15s;}
.nav-back:active{background:rgba(255,255,255,.15);}
.nico{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.75);border-radius:var(--r4);width:36px;height:36px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.88rem;transition:all .15s;flex-shrink:0;}
.nico:active{background:rgba(255,255,255,.18);}
.spill{font-size:.62rem;font-weight:700;padding:3px 9px;border-radius:20px;transition:all .3s;}
.spill.saving{background:rgba(245,158,11,.15);color:var(--gold);}
.spill.saved{background:rgba(34,197,94,.12);color:var(--ok);}
.spill.local{background:rgba(249,115,22,.12);color:var(--warn);}
.auth-pill{display:flex;align-items:center;gap:5px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:5px 11px;cursor:pointer;transition:all .15s;}
.auth-pill:active{background:rgba(255,255,255,.15);}
.adot{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.22);transition:background .3s;}
.adot.on{background:var(--ok);box-shadow:0 0 6px var(--ok);}
.auth-lbl{font-size:.64rem;font-weight:700;color:rgba(255,255,255,.65);}

/* РћђРћђ OFFLINE РћђРћђ */
.offline-bar{background:var(--warn);color:#fff;font-size:.72rem;font-weight:700;padding:6px 16px;text-align:center;display:none;justify-content:center;align-items:center;gap:6px;flex-shrink:0;}
.offline-bar.show{display:flex;}

/* РћђРћђ CONTENT РћђРћђ */
.content{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;overscroll-behavior:contain;background:var(--surf);}
.sc{display:none;min-height:100%;}
.sc.on{display:block;animation:scup .2s ease both;}
@keyframes scup{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}

/* РћђРћђ BOTTOM TABS РћђРћђ */
.tabs{background:var(--bg-deep);height:calc(var(--tab-h)+var(--safe-b));padding-bottom:var(--safe-b);display:none;align-items:flex-start;justify-content:space-around;padding-top:8px;flex-shrink:0;border-top:1px solid rgba(255,255,255,.05);}
.tabs.show{display:flex;}
.tab{display:flex;flex-direction:column;align-items:center;gap:3px;background:none;border:none;cursor:pointer;padding:4px 12px;min-width:52px;position:relative;transition:opacity .2s;}
.tab-ico{color:rgba(255,255,255,.28);transition:color .2s;}
.tab-lbl{font-size:.56rem;font-weight:700;color:rgba(255,255,255,.25);letter-spacing:.3px;transition:color .2s;}
.tab.on .tab-ico{color:var(--gold);}
.tab.on .tab-lbl{color:var(--gold);}
.tab-dot{position:absolute;top:0;right:8px;background:var(--fail);color:#fff;font-size:.48rem;font-weight:900;min-width:14px;height:14px;border-radius:7px;display:none;align-items:center;justify-content:center;padding:0 3px;}
.tab-dot.show{display:flex;}

/* РЋљРЋљРЋљ HOME SCREEN РЋљРЋљРЋљ */
.home-hero{background:linear-gradient(160deg,var(--bg-deep) 0%,var(--bg-mid) 60%,#0a2040 100%);padding:14px 16px 13px;position:relative;overflow:hidden;}
.home-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 80% at 20% 110%,rgba(41,121,255,.18) 0%,transparent 60%),radial-gradient(ellipse 50% 60% at 85% -5%,rgba(245,158,11,.16) 0%,transparent 55%);pointer-events:none;}
.home-eyebrow{font-size:.6rem;font-weight:700;letter-spacing:4px;color:var(--gold);text-transform:uppercase;margin-bottom:6px;position:relative;}
.home-title{font-size:2.2rem;font-weight:900;color:#fff;letter-spacing:-1.5px;line-height:1;position:relative;font-family:'Heebo','Inter',sans-serif;}
.home-title em{color:var(--gold);font-style:normal;}
.home-desc{font-size:.74rem;color:rgba(255,255,255,.38);margin-top:7px;position:relative;}
.kpis{display:grid;grid-template-columns:repeat(3,1fr);margin-top:0;border-radius:11px;overflow:hidden;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.07);}
.kpi{padding:8px 6px;text-align:center;border-left:1px solid rgba(255,255,255,.06);}
.kpi:last-child{border-left:none;}
.kpi-n{font-size:1.8rem;font-weight:900;color:#fff;font-family:'JetBrains Mono',monospace;line-height:1;}
.kpi-l{font-size:.57rem;color:rgba(255,255,255,.3);text-transform:uppercase;letter-spacing:.5px;margin-top:3px;}

/* NEW CL BUTTON Рђћ modern clean card */
.new-cl-card{
  display:flex;align-items:center;gap:16px;
  background:#fff;
  border:1.5px solid rgba(245,158,11,.25);
  border-radius:20px;
  padding:16px 18px;
  cursor:pointer;width:calc(100% - 28px);margin:14px 14px 0;
  box-shadow:0 2px 12px rgba(0,0,0,.06),0 8px 24px rgba(245,158,11,.1);
  transition:transform .18s cubic-bezier(.34,1.4,.64,1),box-shadow .18s;
  text-align:right;position:relative;overflow:hidden;
}
.new-cl-card:active{transform:scale(.97);box-shadow:0 1px 6px rgba(0,0,0,.08);}
.new-cl-icon-wrap{
  width:48px;height:48px;
  background:linear-gradient(135deg,#f59e0b,#f97316);
  border-radius:14px;
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
  box-shadow:0 4px 14px rgba(245,158,11,.4);
}
.new-cl-title{
  font-size:1rem;font-weight:700;
  color:#0f172a;
  letter-spacing:-.3px;
  font-family:'Plus Jakarta Sans','Heebo',sans-serif;
}
.new-cl-sub{font-size:.72rem;color:rgba(255,255,255,.4);}
.new-cl-icon{width:50px;height:50px;background:linear-gradient(135deg,var(--gold),var(--gold2));border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;box-shadow:0 4px 16px var(--gold-glow);}
.new-cl-text{flex:1;}
.new-cl-arrow{color:var(--gold);opacity:.7;flex-shrink:0;}
.new-cl-chevron-wrap{width:30px;height:30px;background:#f8fafc;border:1px solid rgba(0,0,0,.07);border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}

/* SEARCH + FILTER */
.srow{display:flex;gap:8px;padding:12px 14px 6px;}
.sbox{flex:1;display:flex;align-items:center;gap:9px;background:var(--card);border:1.5px solid var(--border);border-radius:28px;padding:10px 14px;box-shadow:var(--sh);}
.sbox svg{opacity:.3;flex-shrink:0;}
.sbox input{flex:1;border:none;outline:none;font-size:.87rem;font-family:inherit;background:transparent;color:var(--t1);}
.sbox input::placeholder{color:var(--t3);}
.aBtn{background:var(--card);border:1.5px solid var(--border);border-radius:12px;width:44px;height:44px;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:var(--sh);flex-shrink:0;}
.aBtn:active{background:var(--card2);}
.chips{display:flex;gap:6px;padding:6px 14px 8px;overflow-x:auto;scrollbar-width:none;}
.chips::-webkit-scrollbar{display:none;}
.chip{background:var(--card);border:1.5px solid var(--border);border-radius:20px;padding:6px 13px;font-size:.7rem;font-weight:700;cursor:pointer;white-space:nowrap;color:var(--t2);box-shadow:var(--sh);flex-shrink:0;}
.chip.on{background:var(--bg-deep);border-color:var(--bg-deep);color:#fff;}
.slbl{font-size:.63rem;font-weight:800;color:var(--t3);text-transform:uppercase;letter-spacing:1px;padding:2px 14px 2px;display:flex;justify-content:space-between;}

/* CL CARD */
.clc{background:var(--card);border-radius:var(--r);padding:15px 16px;margin:0 14px 10px;border:1px solid var(--border);box-shadow:var(--sh);cursor:pointer;transition:border-color .2s,box-shadow .2s;position:relative;}
.clc:active{transform:scale(.982);}
.clc-stripe{position:absolute;right:0;top:0;height:100%;width:4px;border-radius:0 var(--r) 0 0;pointer-events:none;}
.clc-summary{position:relative;}
.clc-name{font-size:.95rem;font-weight:800;color:var(--t1);margin-bottom:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;padding-right:8px;}
.clc-proj{font-size:.67rem;color:var(--blue-accent);font-weight:700;margin-top:2px;}
.clc-meta{font-size:.62rem;color:var(--t3);margin-top:2px;}
.sttag{font-size:.61rem;font-weight:800;padding:4px 10px;border-radius:20px;white-space:nowrap;flex-shrink:0;}
.st-ok{background:var(--ok-d);color:var(--ok);}
.st-warn{background:var(--warn-d);color:var(--warn);}
.st-na{background:rgba(6,16,30,.05);color:var(--t3);}
.ichips{display:flex;gap:4px;flex-wrap:wrap;margin:5px 0 2px;}
.ich{font-size:.6rem;font-weight:800;padding:2px 7px;border-radius:9px;}
.ich-o{background:var(--fail-d);color:var(--fail);}
.ich-c{background:var(--ok-d);color:var(--ok);}
.ich-w{background:var(--purple-d);color:var(--purple);}
.prog{background:rgba(6,16,30,.06);border-radius:8px;height:4px;overflow:hidden;margin:9px 0 6px;}
.prog-f{height:100%;display:flex;border-radius:8px;overflow:hidden;}
.prog-p{background:var(--ok);transition:width .5s;}
.prog-fail{background:var(--fail);transition:width .5s;}
.cnums{display:flex;gap:8px;font-size:.65rem;font-family:'JetBrains Mono',monospace;}
.cn-p{color:var(--ok);font-weight:700;}
.cn-f{color:var(--fail);font-weight:700;}
.cn-r{color:var(--t3);}
.empty{text-align:center;padding:52px 20px;}
.empty-ico{font-size:3rem;opacity:.25;margin-bottom:14px;}
.empty-t{font-size:1rem;font-weight:700;color:var(--t2);margin-bottom:6px;}
.empty-s{font-size:.78rem;color:var(--t3);}

/* РЋљРЋљРЋљ CHECKLIST SCREEN РЋљРЋљРЋљ */
.cl-hero{background:linear-gradient(160deg,var(--bg-deep),var(--bg-mid));padding:16px 18px 20px;position:relative;overflow:hidden;}
.cl-hero::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(245,158,11,.25),transparent);}
.cl-ey{font-size:.58rem;color:rgba(255,255,255,.32);font-weight:700;letter-spacing:2px;text-transform:uppercase;margin-bottom:3px;}
.cl-name{font-size:1.2rem;font-weight:900;color:#fff;letter-spacing:-.3px;min-height:24px;font-family:'Heebo','Inter',sans-serif;}
.cl-sub{font-size:.67rem;color:rgba(255,255,255,.35);margin-top:1px;}
.cl-badge{display:inline-flex;align-items:center;gap:5px;margin-top:7px;font-size:.63rem;font-weight:700;padding:4px 12px;border-radius:20px;background:rgba(255,255,255,.08);color:rgba(255,255,255,.6);}
.cl-prog{height:3px;background:rgba(255,255,255,.06);border-radius:3px;margin-top:13px;overflow:hidden;}
.cl-prog-f{height:100%;background:linear-gradient(90deg,var(--ok),#86efac);border-radius:3px;transition:width .5s ease;}
/* mini stats row */
.cl-ms{display:grid;grid-template-columns:repeat(4,1fr);margin-top:12px;background:rgba(255,255,255,.05);border-radius:11px;overflow:hidden;border:1px solid rgba(255,255,255,.07);}
.cms{padding:9px 4px;text-align:center;border-left:1px solid rgba(255,255,255,.06);}
.cms:last-child{border-left:none;}
.cms-n{font-size:1.05rem;font-weight:900;font-family:'JetBrains Mono',monospace;}
.cms-l{font-size:.52rem;color:rgba(255,255,255,.3);margin-top:1px;}
/* quick actions */
.cl-qa{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-top:11px;}
.qa-btn{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.75);border-radius:9px;padding:8px 4px;font-size:.62rem;font-weight:700;cursor:pointer;font-family:inherit;text-align:center;transition:all .15s;display:flex;flex-direction:column;align-items:center;gap:3px;}
.qa-btn:active{background:rgba(255,255,255,.18);}
.qa-btn svg{opacity:.8;}

/* VIEW-ONLY */
.view-banner{background:var(--purple);color:#fff;font-size:.74rem;font-weight:700;padding:9px 16px;display:flex;align-items:center;justify-content:space-between;gap:10px;}
.view-banner button{background:rgba(255,255,255,.2);border:none;color:#fff;border-radius:6px;padding:5px 12px;font-size:.7rem;font-weight:700;cursor:pointer;font-family:inherit;}

/* SEND ALL */
.send-all-btn{display:none;margin:0 14px 8px;background:linear-gradient(135deg,var(--bg-mid),var(--bg-card));color:var(--gold);border:1px solid rgba(245,158,11,.3);padding:12px 16px;border-radius:var(--r2);font-size:.82rem;font-weight:700;cursor:pointer;font-family:inherit;align-items:center;gap:8px;box-shadow:0 0 20px rgba(245,158,11,.08);}
.send-all-btn.show{display:flex;}

/* CARD */
.card{background:var(--card);border-radius:var(--r);padding:15px;margin:0 14px 8px;border:1px solid var(--border);box-shadow:var(--sh);}
.clabel{font-size:.62rem;font-weight:800;color:var(--t3);text-transform:uppercase;letter-spacing:.8px;margin-bottom:10px;}
.field{margin-bottom:10px;}
.field label{display:block;font-size:.62rem;font-weight:800;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;}
.field input,.field textarea{width:100%;padding:10px 12px;border:1.5px solid var(--border);border-radius:var(--r3);font-size:.87rem;font-family:inherit;background:var(--card2);outline:none;color:var(--t1);transition:border-color .2s;}
.field input:focus,.field textarea:focus{border-color:var(--blue-accent);background:var(--card);}
.field input:disabled,.field textarea:disabled{opacity:.4;cursor:not-allowed;}

/* STATUS */
.ssel{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;}
.sb{padding:11px 4px;border:1.5px solid var(--border);background:var(--card2);border-radius:var(--r3);font-size:.74rem;font-weight:700;cursor:pointer;font-family:inherit;color:var(--t2);text-align:center;transition:all .15s;}
.sb:disabled{opacity:.38;cursor:not-allowed;}
.sb.ns.on{background:var(--t3);border-color:var(--t3);color:#fff;}
.sb.ip.on{background:var(--warn);border-color:var(--warn);color:#fff;}
.sb.dn.on{background:var(--ok);border-color:var(--ok);color:#fff;}

/* ISS BAR */
.iss-bar{display:none;background:var(--card);border-radius:var(--r);padding:12px 15px;margin:0 14px 8px;border:1px solid rgba(239,68,68,.2);box-shadow:var(--sh);cursor:pointer;align-items:center;justify-content:space-between;}
.iss-bar.show{display:flex;}

/* BANNER Рђћ chapter headers redesigned */
.banner{
  margin:22px 14px 10px;
  border-radius:14px;
  overflow:hidden;
  position:relative;
}
.banner-inner{
  background:linear-gradient(135deg,var(--bg-deep) 0%,#0e2a4a 100%);
  padding:14px 16px;
  display:flex;align-items:center;gap:10px;
  border:1px solid rgba(255,255,255,.07);
  border-radius:14px;
  position:relative;overflow:hidden;
}
.banner-inner::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(90deg,rgba(245,158,11,.12) 0%,transparent 60%);
  pointer-events:none;
}
.banner-num{
  font-size:.6rem;font-weight:900;color:var(--gold);
  background:rgba(245,158,11,.15);border:1px solid rgba(245,158,11,.25);
  border-radius:8px;padding:4px 8px;
  font-family:'JetBrains Mono',monospace;letter-spacing:1px;
  flex-shrink:0;
}
.banner-label{
  font-size:.85rem;font-weight:800;color:#fff;
  letter-spacing:-.2px;font-family:'Plus Jakarta Sans','Heebo',sans-serif;
}
.banner-line{
  position:absolute;right:0;top:0;width:3px;height:100%;
  background:linear-gradient(180deg,var(--gold),var(--gold2));
  border-radius:0 14px 14px 0;
}
.bdot{display:none;}/* legacy Рђћ unused */

/* ITEM */
.item{background:var(--card);border-radius:var(--r);padding:14px;margin:0 14px 6px;border:1px solid var(--border);box-shadow:var(--sh);transition:border-right .2s;}
.item.p{border-right:4px solid var(--ok);}
.item.f{border-right:4px solid var(--fail);}
.item.n{border-right:4px solid var(--t3);}
.item-top{display:flex;justify-content:space-between;align-items:flex-start;gap:10px;margin-bottom:10px;}
.item-num{font-size:.6rem;font-weight:900;color:#fff;background:linear-gradient(135deg,var(--blue-accent),#1565c0);padding:3px 8px;border-radius:7px;flex-shrink:0;margin-top:1px;font-family:'JetBrains Mono',monospace;box-shadow:0 1px 4px rgba(41,121,255,.3);}
.item-txt{font-size:.86rem;font-weight:600;line-height:1.5;color:var(--t1);flex:1;font-family:'Heebo','Inter',sans-serif;}
.ibtn{background:transparent;color:var(--t3);border:1.5px solid var(--border);padding:5px 11px;border-radius:20px;font-size:.62rem;font-weight:800;cursor:pointer;flex-shrink:0;text-transform:uppercase;letter-spacing:.5px;transition:all .15s;font-family:'Heebo',inherit;}
.ibtn.hot{background:linear-gradient(135deg,rgba(239,68,68,.12),rgba(239,68,68,.06));color:var(--fail);border-color:rgba(239,68,68,.4);}
.ibtn.iss-wait{background:rgba(249,115,22,.1)!important;color:var(--warn)!important;border-color:rgba(249,115,22,.3)!important;}
.ibtn.iss-closed{background:rgba(34,197,94,.1)!important;color:var(--ok)!important;border-color:rgba(34,197,94,.3)!important;}
.ibtn:disabled{opacity:.38;cursor:not-allowed;}
.pfn-row{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:9px;}
.pfn{padding:12px 6px;border:2px solid var(--border);background:var(--card2);border-radius:12px;font-weight:800;font-size:.76rem;cursor:pointer;font-family:'Heebo','Inter',inherit;text-align:center;transition:all .18s;letter-spacing:.2px;}
.pfn:not(:disabled):hover{border-color:var(--t3);}
.pfn.p.on{background:linear-gradient(135deg,rgba(34,197,94,.15),rgba(34,197,94,.08));color:var(--ok);border-color:var(--ok);box-shadow:0 0 0 3px rgba(34,197,94,.12);}
.pfn.f.on{background:linear-gradient(135deg,rgba(239,68,68,.15),rgba(239,68,68,.08));color:var(--fail);border-color:var(--fail);box-shadow:0 0 0 3px rgba(239,68,68,.12);}
.pfn.n.on{background:linear-gradient(135deg,rgba(100,116,139,.15),rgba(100,116,139,.08));color:var(--t2);border-color:var(--t3);box-shadow:0 0 0 3px rgba(100,116,139,.1);}
.pfn:disabled{opacity:.38;cursor:not-allowed;}
.tools{display:flex;gap:5px;align-items:center;margin-top:4px;}
.tool{background:none;border:none;cursor:pointer;padding:4px;display:inline-flex;align-items:center;border-radius:var(--r4);position:relative;transition:background .15s;}
.tool:active{background:rgba(6,16,30,.06);}
.tbadge2{position:absolute;top:-3px;left:-3px;width:14px;height:14px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.5rem;font-weight:900;color:#fff;}
.note-p{display:none;margin-top:8px;}
.note-p textarea{width:100%;padding:9px 12px;border:1.5px solid var(--border);border-radius:var(--r3);font-size:.82rem;font-family:inherit;resize:none;height:56px;background:var(--card2);outline:none;transition:border-color .2s;}
.note-p textarea:focus{border-color:var(--gold);}
.photo-p{display:none;background:rgba(41,121,255,.06);border:1px dashed rgba(41,121,255,.25);border-radius:var(--r2);padding:10px;margin-top:8px;}
.thumb-row{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:8px;}
.thumb{position:relative;display:inline-block;}
.thumb img{width:72px;height:72px;object-fit:cover;border-radius:var(--r3);border:1.5px solid var(--border);cursor:pointer;}
.tdel{position:absolute;top:-5px;right:-5px;background:var(--fail);color:#fff;border:2px solid var(--card);border-radius:50%;width:18px;height:18px;font-size:.54rem;font-weight:900;cursor:pointer;display:flex;align-items:center;justify-content:center;}
.tdraw{position:absolute;bottom:2px;left:2px;background:rgba(6,16,30,.7);border:none;border-radius:5px;padding:3px 5px;cursor:pointer;display:flex;}
.addph{display:inline-flex;align-items:center;gap:5px;padding:8px 13px;border-radius:var(--r4);font-size:.72rem;font-weight:700;cursor:pointer;}

/* ISSUE */
.iss-p{display:none;background:var(--fail-d);border:1.5px solid rgba(239,68,68,.15);border-radius:14px;padding:12px;margin-top:10px;}
.iss-block{background:var(--card);border:1.5px solid rgba(239,68,68,.18);border-radius:var(--r3);padding:12px;margin-bottom:8px;transition:all .3s;}
.iss-block.closed{border-color:var(--ok-m);background:rgba(34,197,94,.02);}
.iss-block.waiting{border-color:var(--purple-m);background:rgba(168,85,247,.03);}
.iss-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
.iss-num{font-size:.65rem;font-weight:700;color:var(--t3);font-family:'JetBrains Mono',monospace;}
.iss-st{font-size:.63rem;font-weight:800;padding:4px 11px;border-radius:20px;border:none;cursor:pointer;font-family:inherit;transition:all .2s;}
.iss-st.open{background:var(--fail-d);color:var(--fail);}
.iss-st.waiting{background:var(--purple-d);color:var(--purple);}
.iss-st.closed{background:var(--ok-d);color:var(--ok);}
.iss-del{background:var(--fail-d);color:var(--fail);border:none;border-radius:var(--r4);padding:4px 9px;font-size:.65rem;font-weight:700;cursor:pointer;}
.prio-sel{display:flex;gap:5px;margin-bottom:8px;}
.prio-btn{flex:1;padding:6px 4px;border:1.5px solid var(--border);background:var(--card2);border-radius:var(--r4);font-size:.63rem;font-weight:700;cursor:pointer;font-family:inherit;text-align:center;transition:all .15s;}
.prio-btn.sel-h{background:var(--fail-d);border-color:var(--fail-m);color:var(--fail);}
.prio-btn.sel-m{background:var(--warn-d);border-color:rgba(249,115,22,.3);color:var(--warn);}
.prio-btn.sel-l{background:var(--ok-d);border-color:var(--ok-m);color:var(--ok);}
.cpills{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:9px;}
.cpill{background:var(--card2);border:1px solid var(--border);border-radius:var(--r4);padding:5px 10px;font-size:.7rem;font-weight:600;cursor:pointer;transition:all .15s;white-space:nowrap;}
.cpill.sel{background:rgba(41,121,255,.1);border-color:rgba(41,121,255,.22);color:var(--blue-accent);}
.ii{width:100%;padding:9px 12px;border:1.5px solid var(--border);border-radius:var(--r3);font-size:.82rem;font-family:inherit;background:var(--card2);margin-bottom:6px;outline:none;transition:border-color .2s;color:var(--t1);}
.ii:focus{border-color:var(--blue-accent);}
.ii:disabled{opacity:.4;cursor:not-allowed;}
.ita{width:100%;padding:9px 12px;border:1.5px solid var(--border);border-radius:var(--r3);font-size:.82rem;font-family:inherit;resize:none;height:64px;background:var(--card2);margin-bottom:6px;outline:none;transition:border-color .2s;color:var(--t1);}
.ita:focus{border-color:var(--blue-accent);}
.iss-ph{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:6px;}
.iss-ph .thumb img{width:54px;height:54px;}

/* CREATE ISSUE BUTTON */
.create-iss-btn{width:100%;margin-top:8px;padding:11px;background:linear-gradient(135deg,var(--ok),#16a34a);color:#fff;border:none;border-radius:var(--r3);font-size:.82rem;font-weight:800;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:6px;box-shadow:0 3px 12px rgba(34,197,94,.28);transition:all .18s;}
.create-iss-btn:active{transform:scale(.97);}
.create-iss-btn:disabled{background:var(--ok-d);color:var(--ok);box-shadow:none;cursor:default;}

/* FILE ATTACHMENT */
.file-list{display:flex;flex-direction:column;gap:4px;margin-top:8px;}
.file-item{display:flex;align-items:center;gap:7px;background:var(--card);border:1px solid var(--border);border-radius:var(--r4);padding:7px 10px;}
.file-ico{font-size:1rem;flex-shrink:0;}
.file-name{flex:1;font-size:.75rem;font-weight:600;color:var(--t1);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.file-sz{font-size:.62rem;color:var(--t3);flex-shrink:0;}
.file-del{background:var(--fail-d);color:var(--fail);border:none;border-radius:5px;padding:2px 7px;font-size:.62rem;font-weight:700;cursor:pointer;flex-shrink:0;}
.iph-add{display:inline-flex;align-items:center;gap:4px;background:var(--card2);border:1px dashed var(--border2);padding:6px 10px;border-radius:var(--r4);font-size:.68rem;font-weight:600;cursor:pointer;color:var(--t2);}
.create-btn{width:100%;background:linear-gradient(135deg,var(--bg-mid),var(--bg-card));color:rgba(255,255,255,.9);border:1px solid rgba(255,255,255,.1);padding:11px;border-radius:var(--r3);font-size:.82rem;font-weight:700;cursor:pointer;font-family:inherit;margin-top:4px;display:flex;align-items:center;justify-content:center;gap:6px;transition:all .15s;}
.create-btn:active{opacity:.85;}
.add-iss{width:100%;background:rgba(41,121,255,.08);color:var(--blue-accent);border:1px dashed rgba(41,121,255,.25);padding:9px;border-radius:var(--r3);font-size:.74rem;font-weight:700;cursor:pointer;font-family:inherit;margin-top:4px;}
.wait-btn{width:100%;background:var(--purple-d);color:var(--purple);border:1.5px solid var(--purple-m);padding:10px;border-radius:var(--r3);font-size:.8rem;font-weight:800;cursor:pointer;font-family:inherit;margin-top:6px;display:flex;align-items:center;justify-content:center;gap:6px;}

/* ISSUES SCREEN */
.iss-search{width:100%;padding:11px 15px;border:1.5px solid var(--border);border-radius:24px;font-size:.87rem;font-family:inherit;background:var(--card);outline:none;box-shadow:var(--sh);color:var(--t1);}
.iss-card{background:var(--card);border-radius:var(--r);padding:15px;margin:0 14px 8px;cursor:pointer;border:1.5px solid rgba(239,68,68,.18);box-shadow:var(--sh);transition:transform .12s;}
.iss-card:active{transform:scale(.982);}
.iss-card.closed{border-color:var(--ok-m);}
.iss-card.waiting{border-color:var(--purple-m);}
.prio-badge{display:inline-block;font-size:.6rem;font-weight:800;padding:2px 7px;border-radius:8px;}
.pb-h{background:var(--fail-d);color:var(--fail);}
.pb-m{background:var(--warn-d);color:var(--warn);}
.pb-l{background:var(--ok-d);color:var(--ok);}

/* DASHBOARD */
.dash-kpi-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.dash-kpi{background:var(--card);border-radius:var(--r2);padding:14px;border:1px solid var(--border);box-shadow:var(--sh);}
.dk-n{font-size:1.7rem;font-weight:900;font-family:'JetBrains Mono',monospace;margin-bottom:2px;}
.dk-l{font-size:.67rem;color:var(--t3);font-weight:600;}
.ch-prog{height:5px;background:rgba(6,16,30,.06);border-radius:5px;overflow:hidden;}
.ch-prog-f{height:100%;display:flex;border-radius:5px;overflow:hidden;}
.log-item{display:flex;align-items:flex-start;gap:10px;padding:9px 0;border-bottom:1px solid var(--border);}
.log-item:last-child{border-bottom:none;}
.log-dot{width:7px;height:7px;border-radius:50%;background:var(--blue-accent);margin-top:4px;flex-shrink:0;}

/* DRAW */
.draw-ov{position:fixed;inset:0;background:rgba(5,17,31,.97);z-index:9999;display:none;flex-direction:column;align-items:center;padding:14px;gap:10px;overflow-y:auto;}
.draw-ov.show{display:flex;}
#draw-cv{border-radius:12px;max-width:100%;touch-action:none;}
.drow2{display:flex;gap:6px;flex-wrap:wrap;justify-content:center;}
.dcol{width:30px;height:30px;border-radius:50%;border:3px solid transparent;cursor:pointer;transition:border-color .15s;}
.dcol.on{border-color:#fff;}
.dtool{background:rgba(255,255,255,.1);color:rgba(255,255,255,.8);border:1.5px solid rgba(255,255,255,.12);border-radius:var(--r4);padding:7px 12px;font-size:.75rem;cursor:pointer;font-family:inherit;transition:all .15s;}
.dtool.on{background:var(--blue-accent);color:#fff;border-color:var(--blue-accent);}
.dbtn{background:var(--ok);color:#fff;border:none;padding:10px 24px;border-radius:var(--r3);font-weight:700;cursor:pointer;font-family:inherit;font-size:.82rem;}
.dbtn.c{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);}

/* MODALS */
.modal-bg{position:fixed;inset:0;background:rgba(5,17,31,.65);z-index:9000;display:none;align-items:flex-end;backdrop-filter:blur(2px);}
.modal-bg.show{display:flex;animation:mfi .18s ease;}
@keyframes mfi{from{opacity:0;}to{opacity:1;}}
.msheet{background:var(--card);border-radius:24px 24px 0 0;padding:20px;padding-bottom:calc(20px + var(--safe-b));width:100%;max-height:90vh;overflow-y:auto;animation:msu .22s ease;}
@keyframes msu{from{transform:translateY(100%);}to{transform:translateY(0);}}
.mhandle{width:40px;height:4px;background:var(--border2);border-radius:2px;margin:0 auto 18px;}
.cntr-modal{position:fixed;inset:0;background:rgba(5,17,31,.65);z-index:9000;display:none;align-items:center;justify-content:center;padding:20px;backdrop-filter:blur(2px);}
.cntr-modal.show{display:flex;animation:mfi .18s ease;}
.cntr-sheet{background:var(--card);border-radius:22px;padding:24px;width:100%;max-width:390px;box-shadow:var(--sh3);animation:msu .2s ease;}

/* AUTH MODAL */
.auth-modal{position:fixed;inset:0;background:rgba(5,17,31,.9);z-index:10000;display:none;align-items:center;justify-content:center;padding:20px;backdrop-filter:blur(8px);}
.auth-modal.show{display:flex;animation:mfi .2s ease;}
.auth-sheet{background:var(--card);border-radius:22px;padding:28px 24px;width:100%;max-width:340px;box-shadow:var(--sh3);}
.pin-inp{width:100%;padding:14px;border:2px solid var(--border);border-radius:12px;font-size:1rem;font-family:'JetBrains Mono',monospace;letter-spacing:6px;text-align:center;outline:none;background:var(--card2);color:var(--t1);margin-bottom:12px;transition:border-color .2s;}
.pin-inp:focus{border-color:var(--blue-accent);}
.pin-inp.err{border-color:var(--fail);animation:shake .3s ease;}
@keyframes shake{0%,100%{transform:translateX(0);}25%{transform:translateX(-6px);}75%{transform:translateX(6px);}50%{transform:translateX(0);}}
.pin-btn{width:100%;background:linear-gradient(135deg,var(--bg-mid),var(--bg-card));color:#fff;border:1px solid rgba(245,158,11,.3);border-bottom:2px solid var(--gold);padding:13px;border-radius:11px;font-size:.9rem;font-weight:800;cursor:pointer;font-family:inherit;}
.pin-skip{width:100%;background:none;border:none;color:var(--t3);font-size:.78rem;cursor:pointer;padding:10px;font-family:inherit;}

/* SETTINGS */
.sett-row{display:flex;align-items:center;justify-content:space-between;padding:13px 0;border-bottom:1px solid var(--border);}
.sett-row:last-child{border-bottom:none;}
.sett-label{font-size:.82rem;font-weight:700;color:var(--t1);margin-bottom:2px;}
.sett-desc{font-size:.69rem;color:var(--t3);}
.tog{width:44px;height:26px;border-radius:13px;border:none;cursor:pointer;position:relative;flex-shrink:0;transition:background .2s;}
.tog::after{content:'';position:absolute;top:3px;left:3px;width:20px;height:20px;border-radius:50%;background:#fff;box-shadow:0 1px 4px rgba(0,0,0,.2);transition:left .2s;}
.tog.on{background:var(--blue-accent);}
.tog.on::after{left:21px;}
.tog.off{background:rgba(6,16,30,.18);}
.sett-section{font-size:.64rem;font-weight:800;color:var(--t3);text-transform:uppercase;letter-spacing:1px;padding:14px 0 6px;margin-top:4px;}

/* ISSUE FULL PAGE Рђћ MODERN REDESIGN */
.iss-page{position:fixed;inset:0;background:#0d1b2e;z-index:8000;display:none;flex-direction:column;overflow:hidden;}
.iss-page.open{display:flex;animation:scup .22s ease both;}
.iss-page-nav{background:linear-gradient(160deg,#05111f,#0a1f38);padding-top:env(safe-area-inset-top,0px);padding-bottom:16px;padding-left:16px;padding-right:16px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;border-bottom:1px solid rgba(245,158,11,.12);}
.iss-page-body{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:16px 14px 40px;background:#f0f4f8;}
.iss-page-title{font-size:.52rem;font-weight:800;letter-spacing:3px;color:var(--gold);text-transform:uppercase;opacity:.8;}
.iss-page-name{font-size:1rem;font-weight:900;color:#fff;margin-top:2px;letter-spacing:-.3px;}

/* SECTION CARD */
.ip-section-card{background:linear-gradient(135deg,#05111f,#0c2240);border-radius:16px;padding:16px 18px;margin-bottom:14px;border:1px solid rgba(255,255,255,.07);}
.ip-sec-badge{font-size:.55rem;font-weight:800;color:rgba(245,158,11,.7);text-transform:uppercase;letter-spacing:2px;margin-bottom:6px;}
.ip-sec-name{font-size:.88rem;color:#fff;font-weight:700;line-height:1.5;}

/* 2-col ROW */
.ip-row2{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px;}
.ip-card{background:#fff;border-radius:14px;padding:14px;border:1px solid rgba(6,16,30,.07);box-shadow:0 1px 4px rgba(6,16,30,.06);}
.ip-card-lbl{font-size:.56rem;font-weight:800;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;}

/* STATUS BUTTON */
.ip-status-btn{width:100%;border:none;border-radius:10px;padding:12px 8px;font-size:.8rem;font-weight:800;cursor:pointer;font-family:inherit;transition:all .15s;}
.ip-status-btn.open{background:rgba(239,68,68,.1);color:#ef4444;border:1.5px solid rgba(239,68,68,.2);}
.ip-status-btn.waiting{background:rgba(249,115,22,.1);color:#f97316;border:1.5px solid rgba(249,115,22,.2);}
.ip-status-btn.closed{background:rgba(34,197,94,.1);color:#22c55e;border:1.5px solid rgba(34,197,94,.2);}
.ip-status-btn:active{transform:scale(.97);}

/* PRIORITY */
.ip-prio-row{display:flex;gap:4px;}
.ip-prio-btn{flex:1;background:rgba(6,16,30,.04);border:1.5px solid rgba(6,16,30,.08);border-radius:9px;padding:9px 2px;font-size:.72rem;font-weight:700;cursor:pointer;font-family:inherit;display:flex;flex-direction:column;align-items:center;gap:2px;transition:all .15s;color:var(--t3);}
.ip-prio-btn span{font-size:.55rem;font-weight:700;}
.ip-prio-btn.active{border-color:currentColor;opacity:1;transform:scale(1.04);font-weight:900;}
.ip-prio-display{font-size:.82rem;font-weight:800;padding:10px 4px;}

/* CATEGORIES */
.ip-block{background:#fff;border-radius:14px;padding:14px 16px;margin-bottom:12px;border:1px solid rgba(6,16,30,.07);box-shadow:0 1px 4px rgba(6,16,30,.06);}
.ip-block-lbl{font-size:.56rem;font-weight:800;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;}
.ip-cats{display:flex;flex-wrap:wrap;gap:6px;}
.ip-cat{background:rgba(6,16,30,.04);color:#64748b;border:1.5px solid rgba(6,16,30,.08);border-radius:20px;padding:7px 15px;font-size:.72rem;font-weight:700;cursor:pointer;font-family:inherit;transition:all .15s;}
.ip-cat.sel{background:rgba(41,121,255,.1);color:#2979ff;border-color:rgba(41,121,255,.3);}

/* CONTACTS GRID */
.ip-contacts-grid{display:flex;flex-direction:column;gap:8px;}
.ip-contact-card{display:flex;align-items:center;gap:11px;background:rgba(6,16,30,.03);border:1.5px solid rgba(6,16,30,.07);border-radius:12px;padding:11px 13px;cursor:pointer;font-family:inherit;width:100%;text-align:right;transition:all .18s;}
.ip-contact-card.sel{background:rgba(41,121,255,.07);border-color:rgba(41,121,255,.28);}
.ip-contact-card:active{transform:scale(.98);}
.ip-contact-avatar{width:38px;height:38px;border-radius:11px;background:linear-gradient(135deg,#2979ff,#1565c0);color:#fff;font-size:.82rem;font-weight:900;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.ip-contact-info{flex:1;min-width:0;}
.ip-contact-name{font-size:.83rem;font-weight:700;color:#0f172a;}
.ip-contact-email{font-size:.65rem;color:#94a3b8;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.ip-contact-check{width:22px;height:22px;border-radius:50%;background:rgba(41,121,255,.12);color:#2979ff;font-size:.72rem;font-weight:900;display:flex;align-items:center;justify-content:center;flex-shrink:0;opacity:0;transition:opacity .15s;}
.ip-contact-card.sel .ip-contact-check{opacity:1;}

/* FIELD GROUP */
.ip-field-group{display:flex;flex-direction:column;gap:0;}
.ip-field{display:flex;align-items:flex-start;gap:10px;padding:10px 0;border-bottom:1px solid rgba(6,16,30,.05);}
.ip-field:last-child{border-bottom:none;padding-bottom:2px;}
.ip-field-icon{width:32px;height:32px;border-radius:9px;background:rgba(41,121,255,.07);display:flex;align-items:center;justify-content:center;font-size:.88rem;flex-shrink:0;margin-top:1px;}
.ip-field-inner{flex:1;min-width:0;}
.ip-field-lbl{font-size:.57rem;font-weight:800;color:#94a3b8;text-transform:uppercase;letter-spacing:.8px;margin-bottom:5px;}
.ip-input{width:100%;border:none;outline:none;background:transparent;font-size:.86rem;font-family:inherit;color:#0f172a;padding:0;}
.ip-input::placeholder{color:#cbd5e1;}
.ip-textarea{width:100%;border:none;outline:none;background:transparent;font-size:.82rem;font-family:inherit;color:#0f172a;resize:none;min-height:64px;line-height:1.65;}
.ip-textarea::placeholder{color:#cbd5e1;}

/* PHOTOS */
.ip-photos-wrap{display:flex;flex-direction:column;gap:10px;}
.ip-photo-btns{display:flex;gap:8px;}
.ip-photo-btn{flex:1;display:flex;align-items:center;justify-content:center;gap:7px;background:rgba(41,121,255,.08);color:#2979ff;border:1.5px solid rgba(41,121,255,.2);border-radius:12px;padding:12px;font-size:.78rem;font-weight:700;cursor:pointer;font-family:inherit;}
.ip-photo-btn-sec{background:rgba(6,16,30,.04);color:#64748b;border-color:rgba(6,16,30,.1);}

/* ACTION BUTTONS */
.ip-wait-btn{width:100%;background:rgba(249,115,22,.1);color:#f97316;border:1.5px solid rgba(249,115,22,.25);border-radius:14px;padding:15px;font-size:.85rem;font-weight:800;cursor:pointer;font-family:inherit;margin-bottom:10px;display:flex;align-items:center;justify-content:center;gap:8px;}
.ip-confirm-btn{width:100%;background:linear-gradient(135deg,#16a34a,#15803d);color:#fff;border:none;border-radius:14px;padding:17px;font-size:.9rem;font-weight:900;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:9px;box-shadow:0 6px 20px rgba(22,163,74,.28);letter-spacing:-.2px;margin-bottom:10px;}
.ip-confirm-btn:active{transform:scale(.98);}

#fi{position:fixed;top:43%;left:0;background:rgba(5,17,31,.7);border-radius:0 10px 10px 0;z-index:400;display:none;flex-direction:column;align-items:center;gap:4px;cursor:pointer;padding:10px 6px;backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.08);border-left:none;}
#fi.show{display:flex;}
#fi-n{background:var(--fail);color:#fff;font-size:.52rem;font-weight:900;width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;}

/* TOAST */
.toast{position:fixed;bottom:calc(var(--tab-h) + var(--safe-b) + 16px);left:50%;transform:translateX(-50%);background:var(--bg-deep);color:#fff;padding:11px 22px;border-radius:24px;font-size:.78rem;font-weight:600;z-index:8000;box-shadow:var(--sh2);white-space:nowrap;animation:toa .2s ease;pointer-events:none;border:1px solid rgba(255,255,255,.08);}
@keyframes toa{from{opacity:0;transform:translate(-50%,12px);}to{opacity:1;transform:translate(-50%,0);}}

/* LIGHTBOX */
.lb{position:fixed;inset:0;background:rgba(5,17,31,.96);z-index:9990;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-direction:column;gap:12px;}
.lb img{max-width:96vw;max-height:80vh;border-radius:12px;box-shadow:var(--sh3);}
.lb-close{background:rgba(255,255,255,.12);border:none;color:#fff;border-radius:8px;padding:7px 16px;font-size:.8rem;font-weight:700;cursor:pointer;font-family:inherit;}

/* PDF EXPORT */
.pdf-btn{width:calc(100% - 28px);margin:0 14px 8px;background:linear-gradient(135deg,#1a1a2e,#16213e);color:rgba(255,255,255,.85);border:1px solid rgba(168,85,247,.3);padding:13px 16px;border-radius:var(--r2);font-size:.82rem;font-weight:700;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:8px;box-shadow:0 0 20px rgba(168,85,247,.08);}
.csv-btn{width:calc(100% - 28px);margin:0 14px 8px;background:var(--card);color:var(--t2);border:1.5px solid var(--border);padding:12px;border-radius:var(--r2);font-size:.8rem;font-weight:600;cursor:pointer;font-family:inherit;box-shadow:var(--sh);display:flex;align-items:center;justify-content:center;gap:7px;}

/* MISC */
.idate{padding:9px 12px;border:1.5px solid var(--border);border-radius:var(--r3);font-size:.82rem;font-family:inherit;background:var(--card2);outline:none;display:block;max-width:180px;color:var(--t1);}
.idate:focus{border-color:var(--blue-accent);}

/* LOGIN HISTORY */
.log-entry{background:var(--card);border-radius:var(--r2);padding:11px 13px;margin-bottom:6px;border:1px solid var(--border);}
.log-device{font-size:.8rem;font-weight:700;color:var(--t1);margin-bottom:2px;}
.log-meta{font-size:.67rem;color:var(--t3);display:flex;gap:8px;flex-wrap:wrap;}

/* RESPONSIVE TOUCH */
@media (hover:hover){.clc:not(.clc-active):hover{transform:scale(.992)}.new-cl-card:hover{filter:brightness(1.08);transform:translateX(-50%) scale(1.04);}.nico:hover{background:rgba(255,255,255,.14)}}

/* INLINE ACCORDION EXPAND */
.clc-active{border-color:var(--blue-accent)!important;box-shadow:0 0 0 2px rgba(41,121,255,.18),var(--sh2)!important;}
.clc-chev{flex-shrink:0;transition:transform .25s ease;}
.clx-body{display:none;}
.clx-body.open{display:block;animation:clxin .22s ease both;}
@keyframes clxin{from{opacity:0;transform:translateY(-6px);}to{opacity:1;transform:translateY(0);}}
.clx-divider{height:1px;background:var(--border);margin:10px 0 12px;}
.clx-stats{display:grid;grid-template-columns:repeat(4,1fr);background:rgba(6,16,30,.03);border-radius:10px;overflow:hidden;border:1px solid var(--border);margin-bottom:10px;}
.clx-stat{padding:10px 6px;text-align:center;border-left:1px solid var(--border);}
.clx-stat:last-child{border-left:none;}
.clx-stat-n{font-size:1.3rem;font-weight:900;font-family:'JetBrains Mono',monospace;line-height:1;}
.clx-stat-l{font-size:.56rem;color:var(--t3);margin-top:3px;text-transform:uppercase;letter-spacing:.3px;}
.clx-issues{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:8px;}
.clx-detail{font-size:.7rem;color:var(--t3);margin-bottom:4px;}
.clx-actions{display:flex;gap:6px;margin-top:12px;flex-wrap:wrap;}
.clx-btn{flex:1;min-width:0;background:rgba(6,16,30,.05);color:var(--t2);border:1px solid var(--border);border-radius:var(--r4);padding:10px 10px;font-size:.74rem;font-weight:700;cursor:pointer;font-family:inherit;transition:all .15s;text-align:center;white-space:nowrap;}
.clx-btn:active{opacity:.75;}
.clx-btn-open{background:var(--blue-accent);color:#fff;border-color:var(--blue-accent);flex:2;}
.clx-btn-del{background:var(--fail-d);color:var(--fail);border-color:rgba(239,68,68,.2);}

/* РЋљРЋљ SETTINGS APP РЋљРЋљ */
.sett-page{display:none;position:fixed;inset:0;background:#f1f5f9;z-index:5000;flex-direction:column;overflow:hidden;}
.sett-page.open{display:flex;animation:scup .22s ease both;}
/* NAV */
.sett-nav{background:linear-gradient(150deg,#05111f 0%,#091e3a 100%);padding-top:calc(env(safe-area-inset-top,0px) + 4px);display:flex;align-items:center;gap:12px;padding-left:16px;padding-right:16px;padding-bottom:0;flex-shrink:0;position:relative;}
.sett-nav::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1.5px;background:linear-gradient(90deg,transparent 0%,rgba(245,158,11,.5) 50%,transparent 100%);}
.sett-nav-back{background:rgba(255,255,255,.09);border:1px solid rgba(255,255,255,.13);color:rgba(255,255,255,.85);border-radius:9px;padding:8px 14px;font-size:.78rem;font-weight:700;cursor:pointer;font-family:inherit;display:flex;align-items:center;gap:5px;transition:all .15s;}
.sett-nav-back:active{background:rgba(255,255,255,.18);}
.sett-nav-title{flex:1;font-size:.92rem;font-weight:800;color:#fff;text-align:center;letter-spacing:-.2px;font-family:'Heebo','Inter',sans-serif;}
/* HERO */
.sett-hero{background:linear-gradient(150deg,#05111f 0%,#091e3a 100%);padding:18px 18px 32px;flex-shrink:0;}
.sett-hero-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.sett-hero-kpi{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:14px;padding:14px 8px;text-align:center;backdrop-filter:blur(4px);}
.sett-hero-n{font-size:1.5rem;font-weight:900;color:#fff;font-family:'JetBrains Mono',monospace;line-height:1;}
.sett-hero-l{font-size:.57rem;color:rgba(255,255,255,.38);margin-top:4px;text-transform:uppercase;letter-spacing:.6px;font-family:'Heebo','Inter',sans-serif;}
/* BODY */
.sett-body{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding-bottom:env(safe-area-inset-bottom,20px);margin-top:-16px;border-radius:20px 20px 0 0;background:#f1f5f9;position:relative;}
/* SECTION HEADERS */
.sett-sec-hdr{padding:24px 18px 9px;font-size:.6rem;font-weight:800;color:#94a3b8;text-transform:uppercase;letter-spacing:1.8px;font-family:'Heebo','Inter',sans-serif;}
.sett-grp{background:#fff;border-radius:18px;margin:0 14px 10px;overflow:hidden;border:1px solid rgba(6,16,30,.06);box-shadow:0 1px 4px rgba(6,16,30,.04),0 4px 16px rgba(6,16,30,.05);}
.si{display:flex;align-items:center;justify-content:space-between;padding:15px 16px;border-bottom:1px solid rgba(6,16,30,.055);cursor:pointer;min-height:58px;gap:12px;transition:background .12s;}
.si:last-child{border-bottom:none;border-radius:0 0 18px 18px;}
.si:active{background:#f8fafc;}
.si-l{display:flex;align-items:center;gap:13px;flex:1;min-width:0;}
.si-ico{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.05rem;flex-shrink:0;box-shadow:0 2px 8px rgba(0,0,0,.15);}
.si-t{font-size:.87rem;font-weight:700;color:#0f172a;font-family:'Heebo','Inter',sans-serif;}
.si-d{font-size:.71rem;color:#94a3b8;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-top:2px;font-family:'Heebo','Inter',sans-serif;}
.si-r{display:flex;align-items:center;gap:6px;flex-shrink:0;color:var(--t4);}
.sett-sub{display:none;position:fixed;inset:0;background:#f1f5f9;z-index:5100;flex-direction:column;overflow:hidden;}
.sett-sub.open{display:flex;animation:slideInR .22s ease both;}
@keyframes slideInR{from{transform:translateX(50px);opacity:0;}to{transform:translateX(0);opacity:1;}}
.sett-sub-body{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding-bottom:env(safe-area-inset-bottom,20px);}
.stog{width:50px;height:30px;border-radius:15px;border:none;cursor:pointer;position:relative;flex-shrink:0;transition:background .2s;}
.stog::after{content:'';position:absolute;top:3px;left:3px;width:24px;height:24px;border-radius:50%;background:#fff;box-shadow:0 2px 6px rgba(0,0,0,.2);transition:left .2s;}
.stog.on{background:#22c55e;}
.stog.on::after{left:23px;}
.stog.off{background:#e2e8f0;}
.chev{color:#cbd5e1;}
.hist-item{display:flex;align-items:center;gap:13px;padding:14px 16px;border-bottom:1px solid rgba(6,16,30,.055);}
.hist-item:last-child{border-bottom:none;}
.hist-ico{width:42px;height:42px;border-radius:12px;background:linear-gradient(135deg,#eff6ff,#dbeafe);display:flex;align-items:center;justify-content:center;font-size:1.15rem;flex-shrink:0;}
.hist-info{flex:1;}
.hist-dev{font-size:.84rem;font-weight:700;color:#0f172a;font-family:'Heebo','Inter',sans-serif;}
.hist-time{font-size:.71rem;color:#94a3b8;margin-top:2px;font-family:'JetBrains Mono',monospace;}
.danger-btn{width:100%;background:#fff;color:#ef4444;border:1.5px solid rgba(239,68,68,.2);border-radius:14px;padding:14px;font-size:.85rem;font-weight:700;cursor:pointer;font-family:'Heebo','Inter',sans-serif;margin-bottom:10px;display:flex;align-items:center;justify-content:center;gap:8px;transition:all .15s;}
.sett-slider{width:100%;height:4px;accent-color:#2979ff;cursor:pointer;}


/* РћђРћђ ENHANCED ITEM DESIGN РћђРћђ */
.item{border-left:3.5px solid transparent;transition:border-color .2s,box-shadow .2s;}
.item.p{border-left-color:var(--ok);}
.item.f{border-left-color:var(--fail);}
.item.n{border-left-color:var(--t3);}
.item:not(.p):not(.f):not(.n){border-left-color:var(--border2);}
.clabel{font-family:'Heebo','Inter',sans-serif;font-size:.64rem;font-weight:800;letter-spacing:.6px;}
/* better card shadows */
.card,.item,.clc{box-shadow:0 1px 3px rgba(6,16,30,.05),0 3px 12px rgba(6,16,30,.06);}

</style>
</head>
<body>
<div id="app">

<!-- РћђРћђ NAV РћђРћђ -->
<div class="nav" id="app-nav">
  <div class="nav-logo-wrap" id="nav-l">
    <div class="nav-bolt">РџА</div>
    <div class="nav-brand">
      <div class="nav-name">Electra CX</div>
      <div class="nav-sub">Quality Control</div>
    </div>
  </div>
  <div class="nav-r" id="nav-r">
    <div class="auth-pill" id="auth-pill" onclick="showAuthModal()">
      <div class="adot" id="auth-dot"></div>
      <span class="auth-lbl" id="auth-lbl">ОћОфОЌОЉОе</span>
    </div>
    <button class="nico" onclick="showSettings()">РџЎ№ИЈ</button>
  </div>
</div>
<div class="offline-bar" id="offline-bar">­ЪЊА ОљОЎОЪ ОЌОЎОЉОЋОе Рђћ ОбОЋОЉОЊ ОъОДОЋОъОЎОф</div>

<div class="content">

<!-- РЋљРЋљРЋљ HOME РЋљРЋљРЋљ -->
<div id="sc-home" class="sc on">
  <div class="home-hero">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;">
      <div>
        <div class="home-eyebrow">Electra CX ┬и L0</div>
        <div class="home-title" style="font-size:1.6rem;letter-spacing:-1.5px;line-height:1;">ELECTRA <em>CX</em></div>
        <div class="home-desc" style="font-size:.68rem;margin-top:3px;">ОъОбОеОЏОф ОЉОЊОЎОДОф ОюОЋОЌОЋОф ОЌОЕОъОю</div>
      </div>
      <div class="kpis" style="margin-top:0;flex-shrink:0;">
        <div class="kpi"><div class="kpi-n" id="st-tot">0</div><div class="kpi-l">ОАОћ"ОЏ</div></div>
        <div class="kpi"><div class="kpi-n" id="st-ip" style="color:#fbbf24;">0</div><div class="kpi-l">ОцОбОЎОю</div></div>
        <div class="kpi"><div class="kpi-n" id="st-dn" style="color:#4ade80;">0</div><div class="kpi-l">ОАОЎОЎОЮ</div></div>
      </div>
    </div>
  </div>

  <button class="new-cl-card" onclick="requireAuth(newCl)">
    <div class="new-cl-icon-wrap">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    </div>
    <div style="flex:1;">
      <div class="new-cl-title">ОцОфОЌ Од'ОДОюОЎОАОў ОЌОЊОЕ</div>
    </div>
    <div class="new-cl-chevron-wrap">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
    </div>
  </button>

  <div class="srow">
    <div class="sbox">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <input id="home-q" placeholder="ОЌОцОЕ ОюОЋОЌ, ОцОеОЋОЎОДОў, ОЉОЋОЊОД..." oninput="renderHome()">
    </div>
    <button class="aBtn" onclick="showSort()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--t2)" stroke-width="2" stroke-linecap="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="20" y2="12"/><line x1="12" y1="18" x2="20" y2="18"/></svg>
    </button>
    <button class="aBtn" onclick="requireAuth(exportAllCSV)" title="ОЎОЎОдОљ ОћОЏОю">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--t2)" stroke-width="2" stroke-linecap="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
    </button>
  </div>
  <div class="chips">
    <button class="chip on" onclick="setF(this,'all')">ОћОЏОю</button>
    <button class="chip" onclick="setF(this,'in-progress')">ОЉОфОћОюОЎОџ</button>
    <button class="chip" onclick="setF(this,'completed')">ОћОЋОЕОюОъОЋ</button>
    <button class="chip" onclick="setF(this,'not-started')">ОюОљ ОћОфОЌОЎОю</button>
    <button class="chip" onclick="setF(this,'open-issues')">Issues ОцОфОЋОЌОЎОЮ</button>
    <button class="chip" onclick="setF(this,'waiting')">ОъОъОфОЎОЪ ОюОљОЎОЕОЋОе</button>
  </div>
  <div class="slbl"><span id="home-count"></span></div>
  <div id="home-list" style="margin-top:0;"></div>
  <div style="height:20px;"></div>
</div>

<!-- РЋљРЋљРЋљ CHECKLIST РЋљРЋљРЋљ -->
<div id="sc-cl" class="sc">
  <div class="cl-hero">
    <div class="cl-ey">ELECTRA CX ┬и L0 CHECKLIST</div>
    <div class="cl-name" id="cl-name">Од'ОДОюОЎОАОў ОЌОЊОЕ</div>
    <div class="cl-sub" id="cl-sub"></div>
    <div class="cl-badge" id="cl-badge">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      L0 Рђћ ОЉОЊОЎОДОф ОбОЊОЋОф
    </div>
    <div class="cl-prog"><div class="cl-prog-f" id="h-prog" style="width:0%"></div></div>
    <div class="cl-ms">
      <div class="cms"><div class="cms-n" id="cst-p" style="color:#4ade80;">0</div><div class="cms-l">P</div></div>
      <div class="cms"><div class="cms-n" id="cst-f" style="color:#f87171;">0</div><div class="cms-l">F</div></div>
      <div class="cms"><div class="cms-n" id="cst-n" style="color:rgba(255,255,255,.4);">0</div><div class="cms-l">N/A</div></div>
      <div class="cms"><div class="cms-n" id="cst-r" style="color:rgba(255,255,255,.65);">31</div><div class="cms-l">ОаОЋОфОе</div></div>
    </div>
    <div class="cl-qa">
      <button class="qa-btn" onclick="showQuickJump()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        ОДОцОЎОдОћ
      </button>
      <button class="qa-btn" onclick="toggleClSearch()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        ОЌОЎОцОЋОЕ
      </button>
      <button class="qa-btn" onclick="shareChecklist()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
        ОЕОфОБ
      </button>
      <button class="qa-btn" onclick="switchTab('dash')">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        ОАОЎОЏОЋОЮ
      </button>
    </div>
