      const photos=(issuePhotos[itemId]?.[idx]||[]).filter(p=>p?.url);
      html+=`<div style="background:#fff;border-radius:16px;margin-bottom:12px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,.07);cursor:pointer;" onclick="openIssuePage(${itemId},${idx})">
