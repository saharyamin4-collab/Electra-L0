async function confirmRestore(idx){
  if(!isAuthed){toast('­Ъћњ ОаОЊОеОЕОф ОћОеОЕОљОф ОъОаОћОю');return;}
  const bks=getBackups();
  const bk=bks[idx];if(!bk)return;
  const selected=[...document.querySelectorAll('.bk-cl-cb:checked')].map(c=>c.value);
  if(!selected.length){toast('Рџа№ИЈ ОюОљ ОаОЉОЌОеОЋ Од\'ОДОюОЎОАОўОЎОЮ');return;}
  document.getElementById('restore-modal')?.remove();
  toast('РЈ│ ОъОЕОЌОќОе '+selected.length+" Од'ОДОюОЎОАОўОЎОЮ...");

  let ok=0,fail=0;
  for(const id of selected){
    const entry=bk.data[id];if(!entry)continue;
    try{
      const writes=[];
      if(entry.meta)writes.push(db.ref('checklists/'+id+'/meta').set(entry.meta));
      if(entry.data)writes.push(db.ref('checklists/'+id+'/data').set(entry.data));
      await Promise.all(writes);
      // Also restore to localStorage
      if(entry.data){try{localStorage.setItem('cl_'+id,JSON.stringify(entry.data));}catch(e){}}
      ok++;
    }catch(e){fail++;}
  }
  if(ok)loadHome();
  if(fail)toast('Рџа№ИЈ ОЕОЋОЌОќОеОЋ '+ok+', ОаОЏОЕОюОЋ '+fail);
  else toast('РюЁ ОЕОЋОЌОќОеОЋ '+ok+" Од'ОДОюОЎОАОўОЎОЮ ОЉОћОдОюОЌОћ!");
  // Refresh settings panel
  setTimeout(()=>{closeSub();openSub('data');},800);
}

