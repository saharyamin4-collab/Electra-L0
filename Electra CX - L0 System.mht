function mkStatCard(ico,lbl,val,col,bg){
  return '<div style="background:'+bg+';border-radius:12px;padding:12px;text-align:center;border:1px solid rgba(6,16,30,.06);">'+
    '<div style="font-size:1.4rem;font-weight:900;color:'+col+';font-family:\'JetBrains Mono\',monospace;line-height:1;">'+val+'</div>'+
