    // Guests can add photo
    '<label class="iph-add" style="margin-bottom:6px;">­ЪЊи ОћОЋОАОБ ОфОъОЋОаОћ<input type="file" accept="image/*" multiple style="display:none;" onchange="addIssPhoto(this,'+itemId+','+idx+')"></label>'+
    // Guests: only "waiting" button. Admins: create issue button
    (!isAuthed
