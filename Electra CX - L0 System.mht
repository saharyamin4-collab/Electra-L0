      <div class="si" onclick="openSub('checklist')"><div class="si-l"><div class="si-ico" style="background:linear-gradient(135deg,#22c55e,#15803d);">РюЁ</div><div><div class="si-t">ОћОњОЊОеОЋОф Од'ОДОюОЎОАОў</div><div class="si-d">ОЋОЎОЉОеОдОЎОћ, Issue, ОњОюОЎОюОћ</div></div></div><div class="si-r"><svg class="chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></div></div>
      <div class="si" onclick="openSub('contacts')"><div class="si-l"><div class="si-ico" style="background:linear-gradient(135deg,#8b5cf6,#6d28d9);">­ЪЉЦ</div><div><div class="si-t">ОљОаОЕОЎ ОДОЕОе</div><div class="si-d" id="sp-contacts-d">ОўОЋОбОЪ...</div></div></div><div class="si-r"><svg class="chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></div></div>
      <div class="si" onclick="openSub('notifications')"><div class="si-l"><div class="si-ico" style="background:linear-gradient(135deg,#ef4444,#b91c1c);">­Ъћћ</div><div><div class="si-t">ОћОфОеОљОЋОф ОЋОъОЎОЎОюОЎОЮ</div><div class="si-d" id="sp-notif-d">ОўОЋОбОЪ...</div></div></div><div class="si-r"><svg class="chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></div></div>
    </div>
