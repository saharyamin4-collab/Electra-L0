function addPhoto(inp,id){
  if(!inp.files?.length)return;if(!itemPhotos[id])itemPhotos[id]=[];const row=document.getElementById('pt'+id);
  [...inp.files].forEach(f=>{const r=new FileReader();r.onload=e=>{const img=new Image();img.onload=()=>{const c=document.createElement('canvas');const sc=Math.min(1,900/img.width);c.width=img.width*sc;c.height=img.height*sc;c.getContext('2d').drawImage(img,0,0,c.width,c.height);const b64=c.toDataURL('image/jpeg',.75);const idx=itemPhotos[id].length;itemPhotos[id].push({url:b64});row.appendChild(mkThumb(b64,id,idx,'item'));updCB(id);savePhotos(id);};img.src=e.target.result;};r.readAsDataURL(f);});inp.value='';
}

function mkThumb(src,id,idx,type){
  const w=document.createElement('div');w.className='thumb';
  const img=document.createElement('img');img.src=src;img.onclick=()=>openLB(src);
  const del=document.createElement('button');del.className='tdel';del.textContent='РюЋ';
  del.onclick=e=>{
    e.stopPropagation();
    if(!isAuthed){toast('­Ъћњ ОаОЊОеОЕОф ОћОеОЕОљОћ');return;}
    if(type==='item'&&itemPhotos[id]){itemPhotos[id][idx]=null;updCB(id);savePhotos(id);}
    if(type==='iss'&&issuePhotos[id]&&issuePhotos[id][idx]){
      const allT=Array.from(w.parentElement?.children||[]);
      const ti=allT.indexOf(w);
      if(ti>-1)issuePhotos[id][idx][ti]=null;
    }
    w.remove();schedSave();
  };
  if(type==='iss'){const dr=document.createElement('button');dr.className='tdraw';dr.innerHTML='<svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>';dr.onclick=e=>{e.stopPropagation();openDraw(src,ns=>{img.src=ns;schedSave();});};w.appendChild(dr);}
  w.appendChild(img);w.appendChild(del);return w;
}

function updCB(id){const n=(itemPhotos[id]||[]).filter(p=>p).length;const b=document.getElementById('cb'+id);const i=document.getElementById('ci'+id);if(b){b.style.display=n?'flex':'none';b.textContent=n||'';}if(i)i.setAttribute('stroke',n?'var(--blue-accent)':'#94a3b8');}

