function updIssBar(){
  let open=0,closed=0,waiting=0;
  for(let i=1;i<=31;i++){
    const cont=document.getElementById('iss'+i);if(!cont)continue;
    let iOpen=0,iWait=0,iClosed=0;
    cont.querySelectorAll('.iss-block').forEach(bl=>{
      if(bl.dataset.confirmed!=='1')return;
      const s=bl.querySelector('.iss-st')?.dataset.s;
      if(s==='closed'){closed++;iClosed++;}
      else if(s==='waiting'){waiting++;iWait++;}
      else{open++;iOpen++;}
    });
    // Update per-item ISSUE button
    const isb=document.getElementById('isb'+i);
    if(isb){
      const tot=iOpen+iWait+iClosed;
      if(tot===0){
        isb.classList.remove('hot','iss-wait','iss-closed');
        isb.textContent='ISSUE';
      } else {
        isb.classList.add('hot');
        // color by worst status
        if(iOpen>0){isb.classList.remove('iss-wait','iss-closed');}
        else if(iWait>0){isb.classList.add('iss-wait');isb.classList.remove('iss-closed');}
        else{isb.classList.add('iss-closed');isb.classList.remove('iss-wait');}
        const label=iOpen>0?'Рџа№ИЈ':iWait>0?'РЈ│':'РюЊ';
        isb.textContent=label+' '+tot;
      }
    }
  }
  const bar=document.getElementById('iss-bar');const ob=document.getElementById('ib-open');const wb=document.getElementById('ib-wait');const cb=document.getElementById('ib-closed');const fi=document.getElementById('fi');const fin=document.getElementById('fi-n');const tot=open+closed+waiting;
  if(bar)bar.classList.toggle('show',tot>0);
  if(ob){ob.style.display=open>0?'inline-block':'none';ob.textContent='Рџа№ИЈ '+open+' ОцОфОЋОЌ';}
  if(wb){wb.style.display=waiting>0?'inline-block':'none';wb.textContent='РЈ│ '+waiting+' ОъОъОфОЎОЪ';}
  if(cb){cb.style.display=closed>0?'inline-block':'none';cb.textContent='РюЊ '+closed+' ОАОњОЋОе';}
  if(fi)fi.classList.toggle('show',(open+waiting)>0);if(fin)fin.textContent=(open+waiting)||'';
  const tib=document.getElementById('tab-ib');if(tib){tib.classList.toggle('show',(open+waiting)>0);tib.textContent=(open+waiting)||'';}
  const sab=document.getElementById('send-all-btn');
  if(sab)sab.classList.toggle('show',isAuthed&&STATUS==='in-progress'&&(open+waiting)>0);
  // Refresh item issues page if open
  const pg=document.getElementById('iss-page');
  if(pg&&pg.classList.contains('open')&&pg.dataset.itemId&&!pg.dataset.fromItem){
    renderItemIssuesPage(parseInt(pg.dataset.itemId));
  }
}

function setIssWaiting(itemId,idx){
  const btn=document.getElementById('ist-'+itemId+'-'+idx);
  const bl=document.getElementById('ib-'+itemId+'-'+idx);
  if(!btn||btn.dataset.s==='closed')return;
  btn.dataset.s='waiting';btn.className='iss-st waiting';btn.textContent='РЈ│ ОъОъОфОЎОЪ ОюОљОЎОЕОЋОе';
  bl?.classList.remove('closed');bl?.classList.add('waiting');
  logAct('Issue #'+idx+' ОАОбОЎОБ '+itemId+' Рђћ ОъОъОфОЎОЪ ОюОљОЎОЕОЋОе','РЈ│');
  updIssBar();schedSave();toast('РЈ│ ОћОЋОбОЉОе ОюОъОЌОЏОћ ОюОљОЎОЕОЋОе');
}

function cycleIssStatus(itemId,idx){
  if(!isAuthed){
    // viewer can only set to waiting
    const btn=document.getElementById('ist-'+itemId+'-'+idx);
    if(btn&&btn.dataset.s==='open'){setIssWaiting(itemId,idx);}
    else toast('­Ъћњ ОеОД ОъОаОћОю ОЎОЏОЋОю ОюОЕОаОЋОф ОАОўОўОЋОА ОќОћ');
    return;
  }
  const btn=document.getElementById('ist-'+itemId+'-'+idx);
  const bl=document.getElementById('ib-'+itemId+'-'+idx);
  if(!btn)return;
  const cur=btn.dataset.s;
  if(cur==='open'){setIssWaiting(itemId,idx);}
  else if(cur==='waiting'){
    btn.dataset.s='closed';btn.className='iss-st closed';btn.textContent='РюЊ ОАОњОЋОе';
    bl?.classList.remove('waiting');bl?.classList.add('closed');
    logAct('Issue #'+idx+' ОАОбОЎОБ '+itemId+' Рђћ ОАОњОЋОе','­Ъћњ');
    if(navigator.vibrate)navigator.vibrate([50,30,50]);
    updIssBar();schedSave();
  } else {
    btn.dataset.s='open';btn.className='iss-st open';btn.textContent='Рџа№ИЈ ОцОфОЋОЌ';
    bl?.classList.remove('closed');
    updIssBar();schedSave();
  }
}

