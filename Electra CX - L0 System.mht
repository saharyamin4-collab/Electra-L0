function setPFN(btn,id){
  const row=btn.parentElement;const wasOn=btn.classList.contains('on');
  row.querySelectorAll('.pfn').forEach(b=>b.classList.remove('on'));
  if(!wasOn)btn.classList.add('on');
  const el=document.getElementById('ic'+id);
  if(el){el.classList.remove('p','f','n');if(!wasOn){if(btn.classList.contains('p'))el.classList.add('p');else if(btn.classList.contains('f'))el.classList.add('f');else if(btn.classList.contains('n'))el.classList.add('n');}}
  if(settings.vibrateOnPFN&&navigator.vibrate)navigator.vibrate(25);
  if(!wasOn&&btn.classList.contains('f')&&settings.autoOpenIssue)setTimeout(()=>openItemIssuesPage(id),200);
  logAct('ОАОбОЎОБ '+id+': '+(wasOn?'ОЉОЎОўОЋОю':(btn.classList.contains('p')?'Passed':btn.classList.contains('f')?'Failed':'N/A')),btn.classList.contains('p')?'РюЁ':btn.classList.contains('f')?'РЮї':'Рђћ');
  updHeroProg();schedSave();
}

function updHeroProg(){
  let p=0,f=0,na=0;
  for(let i=1;i<=31;i++){const el=document.getElementById('ic'+i);if(!el)continue;if(el.querySelector('.pfn.p.on'))p++;else if(el.querySelector('.pfn.f.on'))f++;else if(el.querySelector('.pfn.n.on'))na++;}
  document.getElementById('h-prog').style.width=Math.round((p+f)/31*100)+'%';
  document.getElementById('cst-p').textContent=p;document.getElementById('cst-f').textContent=f;
  document.getElementById('cst-n').textContent=na;document.getElementById('cst-r').textContent=31-p-f-na;
}

