@media print{body{background:#fff;}.no-print{display:none!important;}tr{page-break-inside:avoid;}}
.wrap{max-width:800px;margin:0 auto;padding:16px;}
.header{background:linear-gradient(135deg,#05111f,#0a2040);color:#fff;padding:22px 24px;border-radius:14px;margin-bottom:14px;display:flex;justify-content:space-between;align-items:center;}
.h-title{font-size:1.35rem;font-weight:900;color:#f59e0b;margin-bottom:4px;}
.h-sub{font-size:.72rem;color:rgba(255,255,255,.4);}
.pct-bar{background:rgba(255,255,255,.12);border-radius:20px;height:5px;width:160px;margin-top:8px;overflow:hidden;}
.pct-fill{background:linear-gradient(90deg,#22c55e,#4ade80);height:100%;border-radius:20px;}
.meta{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px;}
.meta-box{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:11px 13px;}
.meta-lbl{font-size:.6rem;color:#94a3b8;text-transform:uppercase;letter-spacing:.5px;margin-bottom:3px;font-weight:700;}
.meta-val{font-size:.86rem;font-weight:700;}
.kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:14px;}
.kpi{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:12px 6px;text-align:center;}
.kpi-n{font-size:1.7rem;font-weight:900;line-height:1;}
.kpi-l{font-size:.6rem;color:#94a3b8;margin-top:3px;}
.sec{font-size:.72rem;font-weight:800;color:#475569;text-transform:uppercase;letter-spacing:.8px;margin:16px 0 8px;padding-bottom:5px;border-bottom:2px solid #e2e8f0;}
table{width:100%;border-collapse:collapse;background:#fff;border-radius:10px;overflow:hidden;border:1px solid #e2e8f0;margin-bottom:14px;}
.print-btn{position:fixed;bottom:20px;right:20px;background:#05111f;color:#fff;border:none;padding:12px 22px;border-radius:50px;font-family:'Heebo',Arial,sans-serif;font-size:.85rem;font-weight:700;cursor:pointer;box-shadow:0 4px 20px rgba(0,0,0,.25);}

/* РћђРћђ ENHANCED ITEM DESIGN РћђРћђ */
.item{border-left:3.5px solid transparent;transition:border-color .2s,box-shadow .2s;}
.item.p{border-left-color:var(--ok);}
.item.f{border-left-color:var(--fail);}
.item.n{border-left-color:var(--t3);}
.item:not(.p):not(.f):not(.n){border-left-color:var(--border2);}
.clabel{font-family:'Heebo','Inter',sans-serif;font-size:.64rem;font-weight:800;letter-spacing:.6px;}
/* better card shadows */
.card,.item,.clc{box-shadow:0 1px 3px rgba(6,16,30,.05),0 3px 12px rgba(6,16,30,.06);}

</style>
</head>
<body>
<button class="print-btn no-print" onclick="window.print()">­Ъќе ОћОЊОцОА / ОЕОъОЋОе PDF</button>
<div class="wrap">

<div class="header">
  <div>
    <div class="h-title">РџА Electra CX Рђћ L0 Inspection Report</div>
    <div class="h-sub">Quality Control System ┬и ${new Date().toLocaleDateString('he-IL')} ${new Date().toLocaleTimeString('he-IL',{hour:'2-digit',minute:'2-digit'})}</div>
    <div class="pct-bar" style="margin-top:10px;"><div class="pct-fill" style="width:${pct}%;"></div></div>
    <div style="font-size:.68rem;color:rgba(255,255,255,.35);margin-top:4px;">Pass Rate: ${pct}%</div>
  </div>
</div>

<div class="meta">
  <div class="meta-box"><div class="meta-lbl">ОЕОЮ ОћОюОЋОЌ</div><div class="meta-val">${panel}</div></div>
  <div class="meta-box"><div class="meta-lbl">ОъОАО│ ОюОЋОЌ</div><div class="meta-val">${pnum}</div></div>
  <div class="meta-box"><div class="meta-lbl">ОцОеОЋОЎОДОў</div><div class="meta-val">${proj}</div></div>
  <div class="meta-box"><div class="meta-lbl">ОЉОЋОЊОД</div><div class="meta-val">${insp}</div></div>
  <div class="meta-box"><div class="meta-lbl">ОфОљОеОЎОџ</div><div class="meta-val">${fdate}</div></div>
  <div class="meta-box"><div class="meta-lbl">ОъОЎОДОЋОЮ</div><div class="meta-val">${loc}</div></div>
</div>

<div class="kpis">
  <div class="kpi"><div class="kpi-n" style="color:#16a34a;">${p}</div><div class="kpi-l">Passed</div></div>
  <div class="kpi"><div class="kpi-n" style="color:#dc2626;">${f}</div><div class="kpi-l">Failed</div></div>
  <div class="kpi"><div class="kpi-n" style="color:#64748b;">${na}</div><div class="kpi-l">N/A</div></div>
  <div class="kpi"><div class="kpi-n" style="color:#dc2626;">${openIss}</div><div class="kpi-l">Issues ОцОфОЋОЌОЎОЮ</div></div>
</div>

<div class="sec">ОцОЎОеОЋОў ОАОбОЎОцОЎ ОћОЉОЊОЎОДОћ</div>
<table>
  <thead><tr style="background:#f8fafc;"><th style="padding:9px 12px;font-size:.7rem;color:#64748b;text-align:center;width:5%;">#</th><th style="padding:9px 12px;font-size:.7rem;color:#64748b;text-align:right;">ОАОбОЎОБ</th><th style="padding:9px 12px;font-size:.7rem;color:#64748b;text-align:center;width:20%;">ОфОЋОдОљОћ</th></tr></thead>
  <tbody>${itemRows}</tbody>
</table>

${issHtml?`<div class="sec" style="page-break-before:always;">ОъОъОдОљОЎОЮ ОЋ-Issues</div>${issHtml}`:''}
${notes?`<div class="sec">ОћОбОеОЋОф ОЏОюОюОЎОЋОф</div><div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:14px;font-size:.82rem;line-height:1.8;">${notes}</div>`:''}

<div style="text-align:center;margin-top:16px;font-size:.65rem;color:#cbd5e1;">Electra CX Quality Control | ${panel} | ${fdate}</div>
</div></body></html>`;

  const win=window.open('','_blank');
  if(!win){toast('Рџа№ИЈ ОљОцОЕОе ОЌОюОЋОаОЋОф ОДОЋОцОдОЎОЮ ОЉОЊОцОЊОцОЪ');return;}
  win.document.write(html);win.document.close();
  toast('РюЁ ОћОЊОЋОЌ ОаОцОфОЌ Рђћ ОюОЌОЦ ОћОЊОцОА ОюОЕОъОЎОеОћ ОЏ-PDF');
}
function emailPDF(panel,fdate){
  const emails=contacts.filter(c=>c.email).map(c=>c.email).join(',');
  if(!emails&&!settings.notifyEmail){toast('ОюОљ ОћОЋОњОЊОеОЋ ОъОЎОЎОюОЎОЮ ОЉОћОњОЊОеОЋОф');return;}
  const to=emails+(settings.notifyEmail?','+settings.notifyEmail:'');
  const sub=encodeURIComponent('[Electra CX L0] ОЊОЋОЌ ОЉОЊОЎОДОћ Рђћ '+panel);
  const body=encodeURIComponent('ОЕОюОЋОЮ,\n\nОъОдОЋОеОБ ОЊОЋОЌ ОЉОЊОЎОДОф ОбОЊОЋОф L0 ОюОюОЋОЌ: '+panel+'\nОфОљОеОЎОџ: '+fdate+'\n\n(ОЎОЕ ОюОдОеОБ ОљОф ОДОЋОЉОЦ Оћ-PDF ОЕОаОЕОъОе ОюОъОЌОЕОЉОџ)\n\nРђћ Electra CX Quality Control');
  window.location.href='mailto:'+to+'?subject='+sub+'&body='+body;
}

// РЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљ
// LIFECYCLE
// РЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљ
window.addEventListener('online',()=>{document.getElementById('offline-bar').classList.remove('show');toast('РюЁ ОЌОЎОЉОЋОе ОЌОЋОЊОЕ');if(CID)forceSave();});
window.addEventListener('offline',()=>{document.getElementById('offline-bar').classList.add('show');toast('­ЪЊА ОбОЋОЉОЊ ОъОДОЋОъОЎОф');});
document.addEventListener('visibilitychange',()=>{if(document.visibilityState==='hidden'&&CID)forceSave();});
window.addEventListener('beforeunload',()=>{if(CID)forceSave();});


// РЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљ
// INIT
// РЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљРЋљ
const _urlCl=new URLSearchParams(location.search).get('cl');
document.addEventListener('DOMContentLoaded',()=>{
  buildItems();loadSettings();loadContacts();
  if(!navigator.onLine)document.getElementById('offline-bar').classList.add('show');
  if(sessionStorage.getItem('ecx_auth')==='1'){isAuthed=true;updateAuthUI();}
  if(_urlCl){
    const cont=document.querySelector('.content');
    if(cont)cont.scrollTop=0;
    viewCl(_urlCl);
    setTimeout(()=>{
      if(cont)cont.scrollTop=0;
      const backBtn=document.querySelector('.nav-back');
      if(backBtn){
        backBtn.onclick=()=>{
          forceSave();
          setTimeout(()=>{window.history.length>1?history.back():window.close();},300);
        };
      }
    },100);
  } else {
    if(!isAuthed)setTimeout(showAuthModal,1000);
    loadHome();
    // Start hourly auto backup after app loads
    if(settings.autoBackup!==false)setTimeout(startAutoBackup,8000);
  }
});
</script>

<!-- РЋљРЋљ SETTINGS MAIN PAGE РЋљРЋљ -->
